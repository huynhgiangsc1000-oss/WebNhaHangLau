@model DoAnCoSo.Models.ViewModels.LoginViewModel
@{
    Layout = null; // Admin Login không dùng chung Layout với khách
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập Hệ thống Quản trị - Manwah</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        body {
            background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), url('https://manwah.com.vn/wp-content/uploads/2021/07/background-manwah.jpg'); /* Thay link ảnh nền nhà hàng nếu muốn */
            background-size: cover;
            background-position: center;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', Tahoma, sans-serif;
        }

        .login-box {
            width: 400px;
            background: rgba(255, 255, 255, 0.95);
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.5);
        }

        .brand-logo {
            color: #8B0000;
            font-weight: 900;
            font-size: 28px;
            letter-spacing: 2px;
            margin-bottom: 5px;
        }

        .login-title {
            color: #333;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
            margin-bottom: 30px;
        }

        .form-control {
            border-radius: 8px;
            padding: 12px 15px;
            border: 1px solid #ddd;
            margin-bottom: 5px;
        }

            .form-control:focus {
                border-color: #8B0000;
                box-shadow: 0 0 0 0.25 margin rgba(139, 0, 0, 0.25);
            }

        .btn-admin-login {
            background: #8B0000;
            color: white;
            border: none;
            padding: 12px;
            border-radius: 8px;
            font-weight: bold;
            width: 100%;
            transition: 0.3s;
            margin-top: 10px;
        }

            .btn-admin-login:hover {
                background: #660000;
                transform: translateY(-2px);
            }

        .back-link {
            display: block;
            margin-top: 20px;
            text-decoration: none;
            color: #666;
            font-size: 13px;
        }
    </style>
</head>
<body>

    <div class="login-box text-center">
        <div class="brand-logo">MANWAH</div>
        <div class="login-title text-muted">Hệ Thống Quản Trị</div>

        <form asp-area="Admin" asp-controller="Account" asp-action="Login"
              asp-route-returnUrl="@Context.Request.Query["ReturnUrl"]" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3 text-start">
                <label class="form-label small fw-bold text-dark">Số điện thoại Admin</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-person"></i></span>
                    <input asp-for="Phone" class="form-control border-start-0" placeholder="Nhập SĐT..." required />
                </div>
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>

            <div class="mb-3 text-start">
                <label class="form-label small fw-bold text-dark">Mật khẩu</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock"></i></span>
                    <input asp-for="Password" type="password" class="form-control border-start-0" placeholder="••••••••" required />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-3 form-check text-start">
                <input asp-for="RememberMe" class="form-check-input" />
                <label class="form-check-label small text-muted">Duy trì đăng nhập</label>
            </div>

            <button type="submit" class="btn btn-admin-login">ĐĂNG NHẬP HỆ THỐNG</button>

            <a href="/" class="back-link"><i class="bi bi-arrow-left"></i> Quay lại trang chủ khách hàng</a>
        </form>
    </div>

</body>
</html>