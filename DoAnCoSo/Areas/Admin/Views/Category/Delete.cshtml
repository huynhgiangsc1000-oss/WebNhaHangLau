@model DoAnCoSo.Models.Category

<div class="container pt-4 text-center">
    <div class="card shadow-sm border-0 d-inline-block p-5" style="border-radius: 15px; max-width: 500px;">
        <i class="bi bi-exclamation-triangle text-warning" style="font-size: 3rem;"></i>
        <h3 class="fw-bold mt-3">Xác nhận xóa?</h3>
        <p class="text-muted">Bạn có chắc chắn muốn xóa loại món <strong>@Model.CategoryName</strong> không? Hành động này không thể hoàn tác.</p>

        <form asp-action="Delete">
            <input type="hidden" asp-for="CategoryId" />
            <button type="submit" class="btn btn-danger px-4 py-2 me-2">Đúng, Xóa nó!</button>
            <a asp-action="Index" class="btn btn-light px-4 py-2 border">Hủy bỏ</a>
        </form>
    </div>
</div>