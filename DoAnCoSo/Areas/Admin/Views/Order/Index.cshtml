@model IEnumerable<DoAnCoSo.Models.Order>
@Html.AntiForgeryToken()

@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<style>
    /* Hiệu ứng nhấp nháy màu xanh cho đơn chờ thanh toán */
    .blink-awaiting {
        animation: blink-blue 1.5s infinite;
        background-color: #e7f3ff !important;
        font-weight: bold;
    }

    @@keyframes blink-blue {
        0%

    {
        background-color: #e7f3ff;
    }

    50% {
        background-color: #b3d7ff;
    }

    100% {
        background-color: #e7f3ff;
    }

    }
</style>

<div class="container-fluid py-4">
    <div class="card shadow border-0">
        <div class="card-header bg-white py-3">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="m-0 font-weight-bold text-danger">
                        <i class="fas fa-clipboard-list me-2"></i>DANH SÁCH ĐƠN HÀNG
                    </h5>
                </div>
                <div class="col-md-6">
                    <form asp-action="Index" method="get" class="d-flex justify-content-end align-items-center">
                        <input type="text" name="searchQuery" value="@ViewBag.CurrentSearch"
                               class="form-control form-control-sm me-2 w-50" placeholder="Mã đơn, bàn...">
                        <button type="submit" class="btn btn-danger btn-sm px-3">Lọc</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-dark text-center">
                        <tr>
                            <th>STT</th>
                            <th>Mã Đơn</th>
                            <th>Thời gian</th>
                            <th>Bàn</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody class="text-center">
                        @{
                            int i = 1;
                        }
                        @foreach (var item in Model)
                        {
                            decimal rankPct = item.User?.Rank?.DiscountPercent ?? 0;
                            decimal promoPct = item.Promotion?.DiscountValue ?? 0;
                            decimal finalPct = Math.Max(rankPct, promoPct);
                            decimal finalAmount = item.TotalAmount * (1 - (finalPct / 100m));

                            // Kiểm tra trạng thái AwaitingPayment để nhấp nháy
                            string rowClass = item.Status == "AwaitingPayment" ? "blink-awaiting" : "";

                            <tr class="@rowClass">
                                <td>@(i++)</td>
                                <td class="fw-bold text-primary">#@item.OrderId</td>
                                <td>@item.OrderDate.ToString("HH:mm dd/MM")</td>
                                <td>
                                    <span class="badge bg-dark">@item.Table?.TableName</span>
                                </td>
                                <td class="text-danger fw-bold">
                                    @finalAmount.ToString("N0")đ
                                </td>
                                <td>
                                    @switch (item.Status)
                                    {
                                        case "Pending":
                                            <span class="badge rounded-pill bg-warning text-dark">Chờ xác nhận</span>
                                            break;
                                        case "Processing":
                                            <span class="badge rounded-pill bg-info text-white">Đang phục vụ</span>
                                            break;
                                        case "AwaitingPayment":
                                            <span class="badge rounded-pill bg-primary text-white">Chờ thu tiền</span>
                                            break;
                                        case "Completed":
                                            <span class="badge rounded-pill bg-success text-white">Đã hoàn tất</span>
                                            break;
                                        case "Cancelled":
                                            <span class="badge rounded-pill bg-danger text-white">Đã hủy</span>
                                            break;
                                        default:
                                            <span class="badge rounded-pill bg-secondary text-white">@item.Status</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <button class="btn btn-outline-dark btn-sm rounded-pill px-3 me-2"
                                                onclick="showOrderDetail(@item.OrderId)">
                                            <i class="fas fa-eye me-1"></i> Chi tiết
                                        </button>

                                        @if (item.Status == "AwaitingPayment")
                                        {
                                            <button class="btn btn-outline-primary btn-sm rounded-pill px-3"
                                                    onclick="printInvoice(@item.OrderId)">
                                                <i class="fas fa-print me-1"></i> In Bill
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div id="orderDetailContainer"></div>
@Html.AntiForgeryToken()
@section Scripts {
    <script>
        function showOrderDetail(orderId) {
            $('#orderDetailContainer').html('<div class="text-center p-5"><div class="spinner-border text-danger"></div></div>');
            $.get('/Admin/Order/GetDetails/' + orderId, function (data) {
                $('#orderDetailContainer').html(data);
                $('#orderDetailModal').modal('show');
            }).fail(function() {
                alert("Không thể tải chi tiết đơn hàng.");
            });
        }

        function printInvoice(orderId) {
            var width = 800;
            var height = 900;
            var left = (screen.width - width) / 2;
            var top = (screen.height - height) / 2;
            window.open('/Admin/Order/PrintInvoice/' + orderId, '_blank',
                        'width=' + width + ',height=' + height + ',top=' + top + ',left=' + left + ',toolbar=no,location=no,status=no,menubar=no,scrollbars=yes,resizable=yes');
        }

        function updateStatus(id) {
            var status = $('#statusSelect').val();
            var token = $('input[name="__RequestVerificationToken"]').val();

            $('.btn-update-status').prop('disabled', true);

            $.ajax({
                url: '/Admin/Order/UpdateStatus',
                type: 'POST',
                data: {
                    __RequestVerificationToken: token,
                    id: id,
                    status: status
                },
                success: function (response) {
                    if (response.success) {
                        $('#orderDetailModal').modal('hide');
                        location.reload();
                    } else {
                        alert("Lỗi: " + response.message);
                        $('.btn-update-status').prop('disabled', false);
                    }
                }
            });
        }
        function confirmPayment(orderId) {
            if (confirm("Xác nhận đã thu tiền và dọn bàn cho đơn hàng #" + orderId + "?")) {
                // Gọi AJAX đến Action UpdateStatus trong OrderController (Admin)
                $.ajax({
                    url: '/Admin/Order/UpdateStatus',
                    type: 'POST',
                    data: {
                        id: orderId,
                        status: 'Completed'
                    },
                    success: function (res) {
                        if (res.success) {
                            alert("Thanh toán thành công! Bàn đã được giải phóng.");
                            location.reload(); // Load lại trang để thấy bàn trống
                        } else {
                            alert("Lỗi: " + res.message);
                        }
                    },
                    error: function () {
                        alert("Không thể kết nối đến hệ thống. Vui lòng kiểm tra lại Controller!");
                    }
                });
            }
        }
        function executeStatusUpdate(orderId, status) {
            if (confirm("Xác nhận cập nhật trạng thái đơn hàng?")) {
                // Lấy token từ input ẩn mà ASP.NET tự sinh ra
                var token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '/Admin/Order/UpdateStatus',
                    type: 'POST',
                    data: {
                        id: orderId,
                        status: status,
                        __RequestVerificationToken: token // Bắt buộc phải có dòng này
                    },
                    success: function (res) {
                        if (res.success) {
                            location.reload();
                        } else {
                            alert("Lỗi: " + res.message);
                        }
                    },
                    error: function () {
                        alert("Lỗi kết nối hệ thống!");
                    }
                });
            }
        }
    </script>
}