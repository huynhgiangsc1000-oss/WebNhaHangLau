@model IEnumerable<DoAnCoSo.Models.Order>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="container-fluid py-4">
    <div class="card shadow border-0">
        <div class="card-header bg-white py-3">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="m-0 font-weight-bold text-danger">
                        <i class="fas fa-clipboard-list me-2"></i>DANH SÁCH ĐƠN HÀNG
                    </h5>
                </div>
                <div class="col-md-6">
                    <form class="d-flex justify-content-end align-items-center">
                        <input type="text" class="form-control form-control-sm me-2 w-50" placeholder="Mã đơn, bàn...">
                        <input type="date" class="form-control form-control-sm me-2">
                        <button type="submit" class="btn btn-danger btn-sm px-3">Lọc</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-dark text-center">
                        <tr>
                            <th>STT</th>
                            <th>Mã Đơn</th>
                            <th>Thời gian</th>
                            <th>Bàn</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody class="text-center">
                        @{
                            int i = 1;
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@(i++)</td>
                                <td class="fw-bold text-primary">#@item.OrderId</td>
                                <td>@item.OrderDate.ToString("HH:mm dd/MM")</td>
                                <td>
                                    <span class="badge bg-dark">@item.Table?.TableName</span>
                                </td>
                                <td class="text-danger fw-bold">@item.TotalAmount.ToString("N0")đ</td>
                                <td>
                                    @switch (item.Status)
                                    {
                                        case "Pending":
                                            <span class="badge rounded-pill bg-warning text-dark">Chờ xác nhận</span>
                                            break;
                                        case "Processing":
                                            <span class="badge rounded-pill bg-info">Đang chế biến</span>
                                            break;
                                        case "Completed":
                                            <span class="badge rounded-pill bg-success">Đã phục vụ</span>
                                            break;
                                        case "Cancelled":
                                            <span class="badge rounded-pill bg-danger">Đã hủy</span>
                                            break;
                                        default:
                                            <span class="badge rounded-pill bg-secondary">@item.Status</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-outline-dark btn-sm rounded-pill px-3"
                                            onclick="showOrderDetail(@item.OrderId)">
                                        <i class="fas fa-eye me-1"></i> Chi tiết
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div id="orderDetailContainer"></div>

@section Scripts {
    <script>
        function showOrderDetail(orderId) {
            // Hiệu ứng loading nhẹ
            $('#orderDetailContainer').html('<div class="text-center p-5"><div class="spinner-border text-danger"></div></div>');

            $.get('/Admin/Order/GetDetails/' + orderId, function (data) {
                $('#orderDetailContainer').html(data);
                $('#orderDetailModal').modal('show');
            }).fail(function() {
                alert("Không thể tải chi tiết đơn hàng.");
            });
        }

        function updateStatus(id) {
            var status = $('#statusSelect').val();

            // Disable nút để tránh bấm nhiều lần
            $('.btn-update-status').prop('disabled', true);

            $.ajax({
                url: '/Admin/Order/UpdateStatus',
                type: 'POST',
                data: { id: id, status: status },
                success: function (response) {
                    if (response.success) {
                        $('#orderDetailModal').modal('hide');
                        // Sử dụng thông báo đẹp nếu có (như SweetAlert2), nếu không dùng location.reload
                        location.reload();
                    } else {
                        alert("Lỗi: " + response.message);
                        $('.btn-update-status').prop('disabled', false);
                    }
                },
                error: function () {
                    alert("Không thể kết nối đến server.");
                    $('.btn-update-status').prop('disabled', false);
                }
            });
        }
    </script>
}