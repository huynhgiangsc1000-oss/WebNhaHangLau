@model DoAnCoSo.Models.Order
@{
    Layout = null;

    // 1. Lấy mức giảm cao nhất giữa Hạng thành viên và Voucher
    decimal rankPercent = Model.User?.Rank?.DiscountPercent ?? 0;
    decimal promoPercent = Model.Promotion?.DiscountValue ?? 0;
    decimal appliedPercent = Math.Max(rankPercent, promoPercent);

    // 2. Tính toán tiền giảm và tổng thanh toán
    decimal discountAmount = Model.TotalAmount * (appliedPercent / 100m);
    
    decimal depositAmount = 0;
    if (Model.Booking != null && Model.Booking.CheckInCode != null && Model.Booking.CheckInCode.StartsWith("NH-"))
    {
        depositAmount = Model.Booking.TotalAmount * 0.3m;
        if (depositAmount > 0 && depositAmount < 30000) depositAmount = 30000;
    }
    
    decimal finalPrice = Model.TotalAmount - discountAmount - depositAmount;
    if (finalPrice < 0) finalPrice = 0;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>In hóa đơn #@Model.OrderId</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .invoice-card {
            max-width: 800px;
            margin: 30px auto;
            background: white;
            padding: 40px;
            border-top: 8px solid #c0392b;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
        }

        .restaurant-name {
            color: #c0392b;
            font-size: 28px;
            font-weight: 800;
            letter-spacing: 1px;
        }

        .table-invoice thead {
            background-color: #f8f9fa;
        }

        .line-item {
            border-bottom: 1px dashed #dee2e6;
        }

        .total-section {
            min-width: 250px;
        }

        .italic {
            font-style: italic;
        }

        @@media print {
            .no-print

        {
            display: none !important;
        }

        body {
            background-color: white !important;
            margin: 0;
        }

        .invoice-card {
            box-shadow: none !important;
            border: none !important;
            margin: 0 auto;
            width: 100%;
            max-width: 100%;
        }

        }
    </style>
</head>
<body onload="window.print()">
    <div class="container">
        <div class="invoice-card">
            <div class="text-center mb-5">
                <h2 class="restaurant-name text-uppercase">江安火锅 Manwah</h2>
                <h4 class="fw-bold mt-3">HÓA ĐƠN THANH TOÁN</h4>
                <div class="mt-2 text-muted">
                    <i class="far fa-calendar-alt me-1"></i> Ngày: @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-6">
                    <p class="mb-1"><strong>Mã đơn hàng:</strong> <span class="text-danger">#@Model.OrderId</span></p>
                    <p class="mb-1"><strong>Bàn:</strong> <span class="badge bg-dark">@Model.Table?.TableName</span></p>
                </div>
                <div class="col-6 text-end">
                    <p class="mb-1"><strong>Khách hàng:</strong> @(Model.User?.FullName ?? Model.Booking?.FullName ?? "Khách vãng lai")</p>
                    @if (Model.User != null)
                    {
                        <p class="mb-1 small text-muted">Hạng thẻ: @(Model.User.Rank?.RankName ?? "Thành viên")</p>
                    }
                    <p class="mb-1"><strong>Phương thức:</strong> @(Model.PaymentMethod ?? "Tiền mặt")</p>
                </div>
            </div>

            <table class="table table-invoice mt-4">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 50px;">STT</th>
                        <th>Tên món ăn</th>
                        <th class="text-center">Đơn giá</th>
                        <th class="text-center">SL</th>
                        <th class="text-end">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int stt = 1;
                    }
                    @foreach (var detail in Model.OrderDetails)
                    {
                        <tr class="line-item">
                            <td class="text-center">@(stt++)</td>
                            <td>
                                <div class="fw-bold">@detail.Product?.ProductName</div>
                            </td>
                            <td class="text-center">@detail.UnitPrice.ToString("N0")đ</td>
                            <td class="text-center">@detail.Quantity</td>
                            <td class="text-end fw-bold">@((detail.UnitPrice * detail.Quantity).ToString("N0"))đ</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="d-flex justify-content-end mt-4">
                <div class="total-section">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Tạm tính (Giá gốc):</span>
                        <span class="fw-bold">@Model.TotalAmount.ToString("N0")đ</span>
                    </div>

                    @if (appliedPercent > 0)
                    {
                        <div class="d-flex justify-content-between mb-2 text-success small">
                            <span>
                                <i class="fas fa-tags me-1"></i> Giảm giá (@appliedPercent%):
                                <br />
                                <small class="italic">(@(appliedPercent == rankPercent ? "Ưu đãi hạng thẻ" : "Voucher: " + Model.Promotion?.CouponCode))</small>
                            </span>
                            <span class="fw-bold">-@discountAmount.ToString("N0")đ</span>
                        </div>
                    }
                    
                    @if (depositAmount > 0)
                    {
                        <div class="d-flex justify-content-between mb-2 text-primary small">
                            <span>
                                <i class="fas fa-credit-card me-1"></i> Đã đặt cọc (VNPAY):
                            </span>
                            <span class="fw-bold">-@depositAmount.ToString("N0")đ</span>
                        </div>
                    }

                    <hr />
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="fs-5 fw-bold">TỔNG CỘNG:</span>
                        <span class="fs-4 fw-bold text-danger">@finalPrice.ToString("N0")đ</span>
                    </div>
                </div>
            </div>

            <div class="text-center mt-5 border-top pt-4">
                <p class="mb-1 italic">Cảm ơn Quý khách và hẹn gặp lại!</p>
                <p class="small text-muted">Nhân viên in: @(User.Identity.Name ?? "Hệ thống")</p>
                <div class="mt-3">
                    <small>www.江安火锅 Manwah.com.vn | Hotline: 0984 962 700</small>
                </div>
            </div>

            <div class="text-center mt-5 no-print">
                <hr />
                <button onclick="window.print()" class="btn btn-dark px-4 me-2">
                    <i class="fas fa-print me-2"></i> In hóa đơn
                </button>
                <button onclick="window.close()" class="btn btn-outline-secondary px-4">
                    Đóng cửa sổ
                </button>
            </div>
        </div>
    </div>
</body>
</html>