@model DoAnCoSo.Models.Product

<div class="container mt-4" style="max-width: 800px;">
    <div class="card border-0 shadow-sm p-4">
        <h5 class="fw-bold text-danger mb-4">THÊM MÓN ĂN</h5>
        <form asp-action="Create" enctype="multipart/form-data">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Tên món</label>
                    <input asp-for="ProductName" class="form-control" />
                    <span asp-validation-for="ProductName" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-bold">Giá bán</label>
                    <input asp-for="Price" type="number" class="form-control" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Loại món</label>
                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                    <option value="">-- Chọn nhóm con (Bò, Rau, Lẩu...) --</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Hình ảnh</label>
                <input type="file" name="ImageFile" class="form-control" accept="image/*" />
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="form-check form-switch mb-4">
                <input asp-for="IsAvailable" class="form-check-input" type="checkbox" checked>
                <label class="form-check-label">Đang phục vụ</label>
            </div>
            <button type="submit" class="btn btn-danger w-100">LƯU MÓN ĂN</button>
        </form>
    </div>
</div>