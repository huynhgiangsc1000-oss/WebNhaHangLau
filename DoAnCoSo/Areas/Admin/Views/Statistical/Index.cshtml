@using DoAnCoSo.Controllers
@model IEnumerable<TopDishViewModel>

@{
    ViewData["Title"] = "Báo cáo thống kê doanh thu";
}

<div class="container-fluid pt-4 pb-5">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h3 class="fw-bold text-uppercase text-danger mb-1">
                <i class="bi bi-bar-chart-line-fill me-2"></i>Báo cáo & Thống kê
            </h3>
            <p class="text-muted small mb-0">Phân tích doanh thu và hiệu suất nhà hàng theo ngày và ca làm việc</p>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-3 col-sm-6">
                    <label class="form-label small fw-bold text-secondary">Từ ngày:</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-secondary"><i class="bi bi-calendar3"></i></span>
                        <input type="text" id="fromDate" name="fromDate" value="@ViewBag.FromDate" class="form-control border shadow-none vni-datepicker" placeholder="dd/mm/yyyy" />
                    </div>
                </div>
                <div class="col-md-3 col-sm-6">
                    <label class="form-label small fw-bold text-secondary">Đến ngày:</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-secondary"><i class="bi bi-calendar3"></i></span>
                        <input type="text" id="toDate" name="toDate" value="@ViewBag.ToDate" class="form-control border shadow-none vni-datepicker" placeholder="dd/mm/yyyy" />
                    </div>
                </div>
                <div class="col-md-3 col-sm-12">
                    <label class="form-label small fw-bold text-secondary">Xem theo buổi:</label>
                    <select name="sessionFilter" class="form-select border shadow-none">
                        <option value="">-- Tất cả các buổi --</option>
                        <option value="Sang" selected="@(ViewBag.CurrentSession == "Sang")">Buổi Sáng (06:00 - 12:00)</option>
                        <option value="Trua" selected="@(ViewBag.CurrentSession == "Trua")">Buổi Trưa - Chiều (12:00 - 17:00)</option>
                        <option value="Toi" selected="@(ViewBag.CurrentSession == "Toi")">Buổi Tối (17:00 - 24:00)</option>
                    </select>
                </div>
                <div class="col-md-3 col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-danger w-100 fw-bold">
                        <i class="bi bi-filter me-1"></i> LỌC DỮ LIỆU
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary" title="Đặt lại">
                        <i class="bi bi-arrow-clockwise"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card border-0 shadow-sm bg-success text-white">
                <div class="card-body p-3 d-flex align-items-center justify-content-between">
                    <div>
                        <small class="text-uppercase fw-bold opacity-75 d-block" style="font-size: 0.75rem;">Tổng doanh thu (Thực thu)</small>
                        <h4 class="mb-0 fw-bold">@string.Format("{0:N0}", ViewBag.TotalRevenue) đ</h4>
                    </div>
                    <i class="bi bi-currency-dollar display-6 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white">
                <div class="card-body p-3 d-flex align-items-center justify-content-between">
                    <div>
                        <small class="text-uppercase fw-bold opacity-75 d-block" style="font-size: 0.75rem;">Tổng số đơn hàng</small>
                        <h4 class="mb-0 fw-bold">@ViewBag.TotalOrders Đơn</h4>
                    </div>
                    <i class="bi bi-receipt display-6 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card border-0 shadow-sm bg-info text-white">
                <div class="card-body p-3 d-flex align-items-center justify-content-between">
                    <div>
                        <small class="text-uppercase fw-bold opacity-75 d-block" style="font-size: 0.75rem;">Đơn hoàn tất</small>
                        <h4 class="mb-0 fw-bold">@ViewBag.SuccessOrders Đơn</h4>
                    </div>
                    <i class="bi bi-check-circle-fill display-6 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-md-3">
            <div class="card border-0 shadow-sm bg-secondary text-white">
                <div class="card-body p-3 d-flex align-items-center justify-content-between">
                    <div>
                        <small class="text-uppercase fw-bold opacity-75 d-block" style="font-size: 0.75rem;">Đơn bị hủy</small>
                        <h4 class="mb-0 fw-bold">@ViewBag.CancelledOrders Đơn</h4>
                    </div>
                    <i class="bi bi-x-circle-fill display-6 opacity-50"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-8 col-lg-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h6 class="m-0 fw-bold text-dark"><i class="bi bi-graph-up text-danger me-2"></i>Xu hướng doanh thu theo ngày (Thực thu)</h6>
                </div>
                <div class="card-body">
                    <div style="position: relative; height:320px;">
                        <canvas id="revenueChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-lg-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h6 class="m-0 fw-bold text-dark"><i class="bi bi-pie-chart-fill text-danger me-2"></i>Tỷ lệ trạng thái đơn hàng</h6>
                </div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <div style="position: relative; width: 100%; height:260px;">
                        <canvas id="statusChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-header bg-white py-3 border-bottom-0">
            <h5 class="mb-0 fw-bold text-dark">
                <i class="bi bi-trophy-fill me-2 text-warning"></i>Top 5 món ăn có doanh thu cao nhất Manwah
            </h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-secondary border-bottom">
                        <tr>
                            <th class="ps-4 py-3 fw-bold text-uppercase" style="font-size: 0.85rem; width: 10%;">Hạng</th>
                            <th class="py-3 fw-bold text-uppercase" style="font-size: 0.85rem; width: 30%;">Tên món ăn</th>
                            <th class="text-center py-3 fw-bold text-uppercase" style="font-size: 0.85rem; width: 15%;">Số lượng đã bán</th>
                            <th class="text-end py-3 fw-bold text-uppercase" style="font-size: 0.85rem; width: 15%;">Doanh thu gốc</th>
                            <th class="text-end py-3 fw-bold text-uppercase text-danger" style="font-size: 0.85rem; width: 15%;">Tiền giảm giá</th>
                            <th class="text-end pe-4 py-3 fw-bold text-uppercase text-success" style="font-size: 0.85rem; width: 15%;">Doanh thu thực thu</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            int index = 1;
                            foreach (var dish in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        @if (index == 1)
                                        {
                                            <span class="badge bg-warning text-dark"><i class="bi bi-star-fill"></i> Top 1</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-dark">#@index</span>
                                        }
                                    </td>
                                    <td><span class="fw-bold text-dark">@dish.DishName</span></td>
                                    <td class="text-center">
                                        <span class="badge bg-danger-subtle text-danger px-3 py-2 fw-bold">@dish.QuantitySold</span>
                                    </td>
                                    <td class="text-end fw-bold text-secondary">
                                        @string.Format("{0:N0}", dish.OriginalRevenue) đ
                                    </td>
                                    <td class="text-end fw-bold text-danger">
                                        @string.Format("{0:N0}", dish.DiscountRevenue) đ
                                    </td>
                                    <td class="text-end pe-4 fw-bold text-success" style="font-size: 1.05rem;">
                                        @string.Format("{0:N0}", dish.ActualRevenue) đ
                                    </td>
                                </tr>
                                index++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox display-5 d-block mb-2 text-secondary"></i>
                                    Không tìm thấy dữ liệu tiêu thụ món ăn phù hợp với bộ lọc hiện tại.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/vn.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        flatpickr(".vni-datepicker", {
            locale: "vn",
            dateFormat: "d/m/Y",
            allowInput: true
        });

        var ctxRevenue = document.getElementById('revenueChart').getContext('2d');
        var revenueChart = new Chart(ctxRevenue, {
            type: 'line',
            data: {
                labels: [@Html.Raw(ViewBag.ChartLabels)],
                datasets: [{
                    label: 'Doanh thu thực tế (đ)',
                    data: [@ViewBag.ChartData],
                    backgroundColor: 'rgba(220, 53, 69, 0.1)',
                    borderColor: 'rgba(220, 53, 69, 1)',
                    borderWidth: 3,
                    pointBackgroundColor: 'rgba(220, 53, 69, 1)',
                    tension: 0.3,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) { return value.toLocaleString('vi-VN') + ' đ'; }
                        }
                    }
                }
            }
        });

        var ctxStatus = document.getElementById('statusChart').getContext('2d');
        var statusChart = new Chart(ctxStatus, {
            type: 'doughnut',
            data: {
                labels: [@Html.Raw(ViewBag.StatusLabels)],
                datasets: [{
                    data: [@ViewBag.StatusData],
                    backgroundColor: [
                        '#28a745',
                        '#dc3545',
                        '#ffc107',
                        '#17a2b8',
                        '#6c757d'
                    ],
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });
    </script>
}