@model DoAnCoSo.Models.Table

@{
    ViewData["Title"] = "Thêm bàn mới";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 mt-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-plus-circle me-2"></i>Thêm bàn mới</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="TableName" class="form-label fw-bold">Tên bàn hoặc Số bàn</label>
                            <input asp-for="TableName" class="form-control form-control-lg border-2" placeholder="Ví dụ: Bàn số 01, VIP 01..." />
                            <span asp-validation-for="TableName" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Status" class="form-label fw-bold">Trạng thái ban đầu</label>
                            <select asp-for="Status" class="form-select border-2">
                                <option value="Empty">Còn trống</option>
                                <option value="Reserved">Đặt trước</option>
                                <option value="Occupied">Đang sử dụng</option>
                            </select>
                        </div>

                        <div class="alert alert-info border-0 bg-light-info">
                            <i class="bi bi-info-circle-fill me-2 text-info"></i>
                            <small class="text-muted">Mã QR cho bàn này sẽ được hệ thống <strong>tự động sinh ra</strong> dựa trên liên kết thực đơn sau khi bạn nhấn Lưu.</small>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-5">
                            <a asp-action="Index" class="btn btn-light rounded-pill px-4">
                                <i class="bi bi-arrow-left me-1"></i> Quay lại
                            </a>
                            <button type="submit" class="btn btn-danger rounded-pill px-5 fw-bold shadow-sm">
                                <i class="bi bi-check-lg me-1"></i> Lưu bàn
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}