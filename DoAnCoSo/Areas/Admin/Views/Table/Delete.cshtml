@model DoAnCoSo.Models.Table

@{
    ViewData["Title"] = "Xóa bàn";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-danger shadow-sm">
                <div class="card-body text-center p-5">
                    <i class="bi bi-exclamation-triangle text-danger fs-1"></i>
                    <h3 class="mt-3 fw-bold">Xác nhận xóa?</h3>
                    <p class="text-muted">Bạn có chắc chắn muốn xóa <strong>@Model.TableName</strong> không? Hành động này không thể hoàn tác.</p>

                    <div class="alert alert-light border">
                        <small>Trạng thái hiện tại: @Model.Status</small>
                    </div>

                    <form asp-action="Delete" class="mt-4">
                        <input type="hidden" asp-for="TableId" />
                        <a asp-action="Index" class="btn btn-light rounded-pill px-4 me-2">Hủy bỏ</a>
                        <button type="submit" class="btn btn-danger rounded-pill px-4">Xác nhận xóa</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>