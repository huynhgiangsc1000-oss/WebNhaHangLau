@model DoAnCoSo.Models.Table

@{
    ViewData["Title"] = "Chi tiết bàn";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0 text-center p-4">
                <h3 class="fw-bold text-dark">@Model.TableName</h3>
                <p class="text-muted">Trạng thái: <strong>@Model.Status</strong></p>

                <hr />

                <div class="qr-print-area p-3 bg-white border d-inline-block mx-auto mb-3">
                    @if (!string.IsNullOrEmpty(Model.QrCode))
                    {
                        <img src="@Model.QrCode" style="width: 250px; height: 250px;" alt="QR Code" />
                        <p class="mt-2 mb-0 small text-uppercase fw-bold">Quét để gọi món</p>
                    }
                    else
                    {
                        <div class="alert alert-warning">Chưa có mã QR</div>
                    }
                </div>

                <div class="mt-4 d-flex justify-content-center gap-2">
                    <a asp-action="Index" class="btn btn-light rounded-pill px-4 border">Quay lại</a>
                    <button onclick="window.print()" class="btn btn-dark rounded-pill px-4">
                        <i class="bi bi-printer me-1"></i> In mã QR
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>