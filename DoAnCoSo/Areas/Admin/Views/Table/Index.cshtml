@model IEnumerable<DoAnCoSo.Models.Table>

@{
    ViewData["Title"] = "Sơ đồ nhà hàng";
}

<div class="container-fluid shadow-sm p-4 bg-white rounded">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold text-dark mb-1"><i class="bi bi-grid-3x3-gap me-2"></i>Sơ đồ nhà hàng</h4>
            <p class="text-muted small mb-0">Quản lý trạng thái bàn và mã QR gọi món thời gian thực</p>
        </div>
        <a asp-area="Admin" asp-controller="Table" asp-action="Create" class="btn btn-danger shadow-sm rounded-pill px-4">
            <i class="bi bi-plus-lg me-1"></i> Thêm bàn mới
        </a>
    </div>

    <!-- Chú thích trạng thái -->
    <div class="d-flex flex-wrap gap-4 mb-4 pb-3 border-bottom">
        <div class="d-flex align-items-center small">
            <span class="badge bg-success me-2" style="width: 15px; height: 15px; border-radius: 4px;">&nbsp;</span> Bàn trống
        </div>
        <div class="d-flex align-items-center small">
            <span class="badge bg-warning me-2" style="width: 15px; height: 15px; border-radius: 4px;">&nbsp;</span> Có lịch đặt hôm nay
        </div>
        <div class="d-flex align-items-center small">
            <span class="badge bg-danger me-2" style="width: 15px; height: 15px; border-radius: 4px;">&nbsp;</span> Đang có khách/Chờ món
        </div>
    </div>

    <!-- Danh sách bàn -->
    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-5 g-4">
        @foreach (var item in Model)
        {
            // 1. Logic kiểm tra đặt chỗ trong ngày
            var bookingToday = item.Bookings?.FirstOrDefault(b =>
            b.Status == "Confirmed" && b.BookingDate.Date == DateTime.Today);

            bool isOccupied = (item.Status == "Busy" || item.Status == "Occupied");
            bool isReservedToday = bookingToday != null;

            // 2. Định dạng CSS và Text
            string statusClass = isOccupied ? "table-occupied" : (isReservedToday ? "table-reserved" : "table-empty");
            string statusText = isOccupied ? "Đang có khách" : (isReservedToday ? "Đã đặt trước" : "Bàn trống");

            <div class="col" id="table-card-@item.TableId">
                <div class="card h-100 border-0 shadow-sm table-card @statusClass">
                    <div class="card-body text-center p-4">
                        <!-- Icon và Tên bàn -->
                        <i class="bi bi-tablet-landscape mb-2 fs-3"></i>
                        <h5 class="fw-bold mb-1">@item.TableName</h5>
                        <div class="mb-2">
                            <small class="badge bg-light text-dark border fw-normal">
                                <i class="bi bi-people-fill me-1"></i> @item.Capacity người
                            </small>
                        </div>
                        <p class="small mb-1 status-label">@statusText</p>

                        <!-- Detail: Hiển thị giờ hẹn nếu có lịch hôm nay -->
                        <div class="booking-detail" style="height: 35px;">
                            @if (isReservedToday && !isOccupied)
                            {
                                <div class="d-flex flex-column align-items-center">
                                    <span class="badge rounded-pill bg-warning text-dark animate__animated animate__pulse animate__infinite">
                                        <i class="bi bi-clock me-1"></i> @bookingToday.BookingDate.ToString("HH:mm")
                                    </span>
                                    <small class="text-muted" style="font-size: 10px;">@bookingToday.FullName</small>
                                </div>
                            }
                        </div>

                        <!-- QR Code Section -->
                        <div class="qr-wrapper mx-auto mb-3 mt-2">
                            <div class="qr-container bg-white p-2 rounded shadow-sm border">
                                @if (!string.IsNullOrEmpty(item.QrCode))
                                {
                                    <img src="@item.QrCode" class="img-fluid qr-img" alt="QR @item.TableName" />
                                }
                                else
                                {
                                    <div class="small text-muted d-flex align-items-center h-100 justify-content-center">No QR</div>
                                }
                            </div>
                            <form asp-action="RefreshQRCode" asp-route-id="@item.TableId" method="post" class="refresh-qr-form">
                                <button type="submit" class="btn-refresh-qr" title="Làm mới QR">
                                    <i class="bi bi-arrow-repeat"></i>
                                </button>
                            </form>
                        </div>

                        <!-- Nhóm nút chức năng -->
                        <div class="d-flex justify-content-center gap-2 mt-3">
                            <!-- Nút In (Details) -->
                            <a asp-action="Details" asp-route-id="@item.TableId"
                               class="btn btn-sm btn-light rounded-circle border shadow-sm action-btn" title="Xem chi tiết & In QR">
                                <i class="bi bi-printer text-dark"></i>
                            </a>

                            <!-- Nút Giải phóng bàn (Chỉ hiện khi bàn bận) -->
                            @if (isOccupied)
                            {
                                <form asp-action="ResetTable" asp-route-id="@item.TableId" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-success rounded-circle shadow-sm action-btn"
                                            title="Thanh toán / Giải phóng bàn"
                                            onclick="return confirm('Xác nhận khách đã rời bàn?')">
                                        <i class="bi bi-check2-all"></i>
                                    </button>
                                </form>
                            }

                            <!-- Nút Xóa -->
                            <a asp-action="Delete" asp-route-id="@item.TableId"
                               class="btn btn-sm btn-outline-danger rounded-circle shadow-sm action-btn"
                               title="Xóa bàn" onclick="return confirm('Bạn có chắc muốn xóa bàn này?')">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* Card hiệu ứng chung */
    .table-card {
        transition: all 0.3s cubic-bezier(.25,.8,.25,1);
        border: 2px solid transparent !important;
        position: relative;
    }

        .table-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 24px rgba(0,0,0,0.15) !important;
        }

    /* Định dạng QR */
    .qr-wrapper {
        position: relative;
        width: 100px;
        height: 100px;
    }

    .qr-container {
        width: 100%;
        height: 100%;
        overflow: hidden;
    }

    .qr-img {
        transition: transform 0.3s ease;
    }

    .qr-wrapper:hover .qr-img {
        transform: scale(1.1);
    }

    /* Nút làm mới QR nhỏ xinh */
    .btn-refresh-qr {
        position: absolute;
        bottom: -5px;
        right: -5px;
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 50%;
        width: 28px;
        height: 28px;
        font-size: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        color: #6c757d;
        transition: 0.2s;
    }

        .btn-refresh-qr:hover {
            background: #0d6efd;
            color: white;
            border-color: #0d6efd;
        }

    /* TRẠNG THÁI 1: BÀN TRỐNG (Xanh) */
    .table-empty {
        background-color: #f0fff4 !important;
        border-color: #c6f6d5 !important;
    }

        .table-empty .status-label, .table-empty i.bi-tablet-landscape {
            color: #38a169;
            font-weight: 600;
        }

    /* TRẠNG THÁI 2: ĐÃ ĐẶT TRƯỚC (Vàng) */
    .table-reserved {
        background-color: #fffaf0 !important;
        border-color: #fbd38d !important;
    }

        .table-reserved .status-label, .table-reserved i.bi-tablet-landscape {
            color: #dd6b20;
            font-weight: 600;
        }

    /* TRẠNG THÁI 3: ĐANG CÓ KHÁCH (Đỏ) */
    .table-occupied {
        background-color: #fff5f5 !important;
        border-color: #feb2b2 !important;
    }

        .table-occupied .status-label, .table-occupied i.bi-tablet-landscape {
            color: #e53e3e;
            font-weight: 600;
        }

    /* Nút hành động tròn */
    .action-btn {
        width: 36px;
        height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: 0.2s;
    }

    /* Animation cho badge giờ hẹn */
    @@keyframes pulse {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.05);
        }

        100% {
            transform: scale(1);
        }
    }

    .animate__pulse {
        animation: pulse 2s infinite;
    }
</style>