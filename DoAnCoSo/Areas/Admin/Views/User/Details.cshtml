@model DoAnCoSo.Models.User

@{
    ViewData["Title"] = "Chi tiết khách hàng";
    var orders = ViewBag.Orders as IEnumerable<DoAnCoSo.Models.Order>;
}

<div class="container-fluid pt-4">
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-2">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách
        </a>
        <h4 class="fw-bold text-dark">Hồ sơ khách hàng: @Model.FullName</h4>
    </div>

    <div class="row">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 15px;">
                <div class="card-body text-center pt-5">
                    <div class="mx-auto bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold mb-3"
                         style="width: 100px; height: 100px; font-size: 2.5rem;">
                        @Model.FullName.Substring(0, 1).ToUpper()
                    </div>

                    <h5 class="fw-bold mb-1">@Model.FullName</h5>
                    <p class="text-muted mb-3">ID Khách hàng: #@Model.Id</p>

                    @if (Model.Rank != null)
                    {
                        var badgeClass = Model.Rank.RankName switch
                        {
                            "Vàng" => "bg-warning text-dark",
                            "Bạc" => "bg-info text-dark",
                            "Đồng" => "bg-secondary text-white",
                            _ => "bg-light text-dark border"
                        };
                        <div class="badge @badgeClass fs-6 px-3 py-2 mb-3">
                            <i class="bi bi-trophy-fill me-1"></i> @Model.Rank.RankName
                        </div>
                    }

                    <hr class="my-4">

                    <div class="text-start">
                        <div class="mb-3">
                            <label class="small text-muted d-block">Số điện thoại</label>
                            <span class="fw-bold">@Model.PhoneNumber</span>
                        </div>
                        <div class="mb-3">
                            <label class="small text-muted d-block">Ngày tham gia</label>
                            <span class="fw-bold">@Model.CreatedAt.ToString("dd/MM/yyyy")</span>
                        </div>
                    </div>

                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary w-100 mt-2">
                        <i class="bi bi-pencil-square"></i> Chỉnh sửa hồ sơ
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm text-center p-3 bg-white" style="border-radius: 12px;">
                        <div class="text-muted small mb-1">Tổng chi tiêu</div>
                        <div class="h5 fw-bold text-success mb-0">@ViewBag.TotalSpent.ToString("N0")đ</div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm text-center p-3 bg-white" style="border-radius: 12px;">
                        <div class="text-muted small mb-1">Điểm hiện tại</div>
                        <div class="h5 fw-bold text-warning mb-0">@Model.Points.ToString("N0") <i class="bi bi-coin"></i></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card border-0 shadow-sm text-center p-3 bg-white" style="border-radius: 12px;">
                        <div class="text-muted small mb-1">Món yêu thích</div>
                        <div class="h5 fw-bold text-primary mb-0" style="font-size: 1rem;">@ViewBag.TopProduct</div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0" style="border-radius: 15px;">
                <div class="card-header bg-white py-3">
                    <h6 class="m-0 fw-bold text-dark">Lịch sử đơn hàng (@ViewBag.OrderCount)</h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-3">Mã đơn</th>
                                    <th>Ngày đặt</th>
                                    <th>Tổng tiền</th>
                                    <th>Trạng thái</th>
                                    <th class="text-end pe-3">Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (orders != null && orders.Any())
                                {
                                    foreach (var order in orders)
                                    {
                                        <tr>
                                            <td class="ps-3 fw-bold">#@order.OrderId</td>
                                            <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="text-dark fw-bold">@order.TotalAmount.ToString("N0")đ</td>
                                            <td>
                                                @{
                                                    var statusClass = order.Status switch
                                                    {
                                                        "Paid" => "bg-success",
                                                        "Pending" => "bg-warning text-dark",
                                                        "Cancelled" => "bg-danger",
                                                        _ => "bg-secondary"
                                                    };
                                                    var statusText = order.Status switch
                                                    {
                                                        "Paid" => "Đã thanh toán",
                                                        "Pending" => "Chờ xử lý",
                                                        "Cancelled" => "Đã hủy",
                                                        _ => order.Status
                                                    };
                                                }
                                                <span class="badge @statusClass" style="font-size: 0.7rem;">@statusText</span>
                                            </td>
                                            <td class="text-end pe-3">
                                                <a asp-controller="Order" asp-action="Index" asp-route-searchTable="@order.OrderId"
                                                   class="btn btn-sm btn-light border">
                                                    <i class="bi bi-search"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">Khách hàng này chưa có đơn hàng nào.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        transition: transform 0.2s;
    }

    .table thead th {
        font-size: 0.75rem;
        text-transform: uppercase;
        font-weight: 700;
        color: #6c757d;
        border: none;
    }

    .badge {
        padding: 0.5em 0.8em;
        border-radius: 6px;
    }
</style>