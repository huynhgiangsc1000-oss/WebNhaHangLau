@model DoAnCoSo.Models.User
@{
    ViewData["Title"] = "Chi tiết khách hàng";
    var orders = ViewBag.Orders as IEnumerable<DoAnCoSo.Models.Order>;
}

@functions {
    string TranslateStatus(string status)
    {
        return status switch
        {
            DoAnCoSo.Models.Order.StatusPending => "Chờ xử lý",
            DoAnCoSo.Models.Order.StatusCompleted => "Hoàn thành",
            DoAnCoSo.Models.Order.StatusCancelled => "Đã hủy",
            _ => status
        };
    }
    string GetStatusClass(string status)
    {
        return status switch
        {
            DoAnCoSo.Models.Order.StatusPending => "bg-warning text-dark",
            DoAnCoSo.Models.Order.StatusCompleted => "bg-success",
            DoAnCoSo.Models.Order.StatusCancelled => "bg-danger",
            _ => "bg-secondary"
        };
    }
}

<div class="container-fluid pt-4">
    <div class="mb-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Quay lại</a>
        <h4 class="fw-bold mt-2">Hồ sơ: @Model.FullName</h4>
    </div>

    @if (orders != null && orders.Any())
    {
        int dayIndex = 0;
        @foreach (var dayGroup in orders.GroupBy(o => o.OrderDate.Date))
        {
            dayIndex++;
            string collapseId = "day_" + dayIndex;

            <div class="bg-primary text-white px-3 py-2 fw-bold mt-4 mb-2 rounded shadow-sm"
                 data-bs-toggle="collapse" data-bs-target="#@collapseId" style="cursor: pointer;">
                <i class="bi bi-calendar-check me-2"></i> NGÀY: @dayGroup.Key.ToString("dd/MM/yyyy")
            </div>

            <div class="collapse show" id="@collapseId">
                @foreach (var shiftGroup in dayGroup.GroupBy(o => o.OrderDate.Hour < 12 ? "Sáng" : (o.OrderDate.Hour < 18 ? "Chiều" : "Tối")))
                {
                    <div class="ms-3 mb-2 fw-bold text-primary"><i class="bi bi-clock me-1"></i> @shiftGroup.Key</div>

                    <div class="card shadow-sm border-0 mb-3 ms-4">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-muted small">
                                <tr>
                                    <th>Mã đơn</th>
                                    <th>Giờ đặt</th>
                                    <th>Giá gốc</th>
                                    <th>Giảm giá</th>
                                    <th>Thành tiền</th>
                                    <th>Trạng thái</th>
                                    <th class="text-end">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in shiftGroup)
                                {
                                   
                                    var thanhTienThucTe = order.TotalAmount - order.DiscountAmount;

                                    <tr>
                                        <td class="fw-bold">#@order.OrderId</td>
                                        <td>@order.OrderDate.ToString("HH:mm")</td>

                                        <td class="text-muted">@order.TotalAmount.ToString("N0")đ</td>

                                        <td class="text-danger fw-bold">
                                            -@order.DiscountAmount.ToString("N0")đ
                                            @if (order.AppliedDiscountPercent > 0)
                                            {
                                                <small>(@(order.AppliedDiscountPercent.ToString("0"))%)</small>
                                            }
                                        </td>

                                        <td class="text-success fw-bold">@thanhTienThucTe.ToString("N0")đ</td>

                                        <td><span class="badge @GetStatusClass(order.Status)">@TranslateStatus(order.Status)</span></td>
                                        <td class="text-end">
                                            <a asp-controller="Order" asp-action="Index" asp-route-searchTable="@order.OrderId"
                                               class="btn btn-sm btn-outline-primary shadow-sm"><i class="bi bi-eye"></i> Xem đơn</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }

        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Details" asp-route-id="@ViewBag.UserId" asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
    else
    {
        <div class="alert alert-info">Khách hàng chưa có lịch sử đơn hàng nào.</div>
    }
</div>