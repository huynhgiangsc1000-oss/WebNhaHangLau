@model IEnumerable<DoAnCoSo.Models.User>

@{
    ViewData["Title"] = "Quản lý khách hàng";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

<div class="container-fluid pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold text-dark m-0">Quản lý khách hàng</h4>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item active">Danh sách khách hàng</li>
                </ol>
            </nav>
        </div>
        <div class="badge bg-primary bg-opacity-10 text-primary p-2 px-3 rounded-pill">
            <i class="bi bi-people-fill me-1"></i> Tổng: @Model.Count() người dùng
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-4">
            <div class="bg-light p-3 rounded-4 mb-4">
                <form asp-action="Index" method="get" class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="small text-muted fw-bold">Tìm kiếm</label>
                        <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control rounded-3" placeholder="Tên hoặc SĐT...">
                    </div>
                    <div class="col-md-3">
                        <label class="small text-muted fw-bold">Hạng thành viên</label>
                        <select name="rankId" class="form-select rounded-3" asp-items="ViewBag.Ranks">
                            <option value="">-- Tất cả --</option>
                        </select>
                    </div>
                    <div class="col-md-6 d-flex gap-2 justify-content-md-end">
                        <button type="submit" class="btn btn-primary rounded-3 px-4"><i class="bi bi-search me-1"></i>Lọc</button>
                        <a asp-action="Index" class="btn btn-outline-secondary rounded-3"><i class="bi bi-arrow-counterclockwise"></i></a>
                        <button type="button" onclick="confirmScan()" class="btn btn-warning fw-bold rounded-3">
                            <i class="bi bi-magic me-1"></i>QUÉT HẠNG
                        </button>
                    </div>
                </form>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="text-secondary border-bottom-0">
                        <tr>
                            <th class="ps-3">Khách hàng</th>
                            <th>Liên hệ</th>
                            <th>Điểm tích lũy</th>
                            <th>Hạng</th>
                            <th>Trạng thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold me-3" style="width: 40px; height: 40px;">
                                            @item.FullName.Substring(0, 1).ToUpper()
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@item.FullName</div>
                                            <small class="text-muted">ID: @item.Id</small>
                                        </div>
                                    </div>
                                </td>
                                <td><i class="bi bi-telephone text-muted me-1"></i>@item.PhoneNumber</td>
                                <td><span class="fw-bold text-dark">@item.Points.ToString("N0")</span></td>
                                <td>
                                    <span class="badge @(item.Rank?.RankName == "Vàng" ? "bg-warning text-dark" : "bg-light text-dark border") rounded-pill">
                                        @(item.Rank?.RankName ?? "Chưa có")
                                    </span>
                                </td>
                                <td>
                                    <form asp-action="ToggleLock" asp-route-id="@item.Id" method="post" id="lockForm_@item.Id">
                                        <button type="button" onclick="confirmLock(@item.Id, @item.IsLocked.ToString().ToLower())"
                                                class="btn btn-sm @(item.IsLocked ? "btn-danger" : "btn-outline-warning")">
                                            @(item.IsLocked ? "Đã khóa" : "Hoạt động")
                                        </button>
                                    </form>
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-icon btn-sm btn-light"><i class="bi bi-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-icon btn-sm btn-light text-primary"><i class="bi bi-pencil"></i></a>
                                        <button onclick="deleteUser(@item.Id)" class="btn btn-icon btn-sm btn-light text-danger"><i class="bi bi-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-page="@i"
                               asp-route-searchString="@ViewBag.SearchString"
                               asp-route-rankId="@ViewBag.RankId">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    </div>
</div>

<form id="deleteForm" method="post" asp-action="Delete" style="display:none;"><input type="hidden" name="id" id="deleteId" /></form>
<form id="scanForm" method="post" asp-action="UpdateAllRanks" style="display:none;"></form>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    // 1. TỰ ĐỘNG HIỂN THỊ THÔNG BÁO TỪ CONTROLLER
       document.addEventListener("DOMContentLoaded", function () {
           @if (TempData["Warning"] != null)
           {
                   <text>
                   Swal.fire({
                       icon: 'warning',
                       title: 'Thông báo', // Đổi tiêu đề thành Thông báo
                       // Sử dụng @Json.Serialize để tránh lỗi font chữ
                       text: @Json.Serialize(TempData["Warning"]),
                       confirmButtonColor: '#f39c12'
                   });
                   </text>
           }

           // Làm tương tự với TempData["Success"]
           @if (TempData["Success"] != null)
           {
                   <text>
                   Swal.fire({
                       icon: 'success',
                       title: 'Thành công',
                       text: @Json.Serialize(TempData["Success"]),
                       timer: 2000,
                       showConfirmButton: false
                   });
                   </text>
           }
       });
    // 2. HÀM XÁC NHẬN CẬP NHẬT HẠNG
    function confirmScan() {
        Swal.fire({
            title: 'Cập nhật hạng?',
            text: "Hệ thống sẽ tính lại hạng cho toàn bộ khách hàng.",
            icon: 'question',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            confirmButtonText: 'Tiến hành'
        }).then((result) => {
            if (result.isConfirmed) { document.getElementById('scanForm').submit(); }
        });
    }

    // 3. HÀM XÁC NHẬN KHÓA/MỞ KHÓA
    function confirmLock(id, isLocked) {
        Swal.fire({
            title: isLocked ? 'Mở khóa tài khoản?' : 'Khóa tài khoản?',
            text: isLocked ? "Khách hàng sẽ có thể đăng nhập lại." : "Khách hàng sẽ không thể đăng nhập.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: isLocked ? '#28a745' : '#d33',
            confirmButtonText: 'Đồng ý'
        }).then((result) => {
            if (result.isConfirmed) { document.getElementById('lockForm_' + id).submit(); }
        });
    }

    // 4. HÀM XÁC NHẬN XÓA
    function deleteUser(id) {
        Swal.fire({
            title: 'Xóa vĩnh viễn?',
            text: "Hành động này không thể hoàn tác!",
            icon: 'error',
            showCancelButton: true,
            confirmButtonColor: '#d33',
            cancelButtonColor: '#3085d6',
            confirmButtonText: 'Xóa ngay'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteForm').submit();
            }
        });
    }
</script>