@model DoAnCoSo.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Đăng nhập & Đăng ký";
    // Lấy returnUrl từ Query String hoặc ViewData
    var returnUrl = Context.Request.Query["ReturnUrl"];
}

<div class="auth-wrapper">
    <div class="auth-container" id="auth-container">
        <div class="form-container sign-up-container">
            @* Thêm asp-route-returnurl vào form đăng ký *@
            <form asp-action="Register" asp-route-returnurl="@returnUrl" method="post">
                <h2 class="fw-bold text-danger">TẠO TÀI KHOẢN</h2>
                <p class="small text-muted">Trở thành thành viên của Manwah ngay hôm nay</p>
                <input type="text" name="FullName" placeholder="Họ và Tên" required />
                <input type="tel" name="Phone" placeholder="Số điện thoại" required />
                <input type="password" name="Password" placeholder="Mật khẩu" required />
                <input type="password" name="ConfirmPassword" placeholder="Xác nhận mật khẩu" required />
                <button class="btn-auth" type="submit">ĐĂNG KÝ</button>
            </form>
        </div>

        <div class="form-container sign-in-container">
            @* Thêm asp-route-returnurl vào form đăng nhập *@
            <form asp-action="Login" asp-route-returnurl="@returnUrl" method="post">
                <h2 class="fw-bold text-danger">ĐĂNG NHẬP</h2>
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                <input asp-for="Phone" placeholder="Số điện thoại (0xxx...)" />
                <span asp-validation-for="Phone" class="text-danger small"></span>

                <input asp-for="Password" type="password" placeholder="Mật khẩu" />
                <span asp-validation-for="Password" class="text-danger small"></span>

                <div class="mb-3 mt-2 form-check w-100 text-start">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label class="form-check-label small text-muted">Ghi nhớ đăng nhập</label>
                </div>

                <button class="btn-auth" type="submit">ĐĂNG NHẬP</button>
                <a href="#" class="mt-3 text-muted small">Quên mật khẩu?</a>
            </form>
        </div>

        <div class="overlay-container">
            <div class="overlay">
                <div class="overlay-panel overlay-left">
                    <h2 class="fw-bold">Chào mừng trở lại!</h2>
                    <p>Để giữ kết nối với Manwah, vui lòng đăng nhập bằng tài khoản cá nhân của bạn</p>
                    <button class="ghost" id="signIn">ĐĂNG NHẬP</button>
                </div>
                <div class="overlay-panel overlay-right">
                    <h2 class="fw-bold">Xin chào bạn!</h2>
                    <p>Nhập thông tin cá nhân của bạn để bắt đầu hành trình ẩm thực tại Manwah</p>
                    <button class="ghost" id="signUp">ĐĂNG KÝ NGAY</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .auth-container {
            background-color: #fff;
            border-radius: 15px;
            box-shadow: 0 14px 28px rgba(0,0,0,0.25);
            position: relative;
            overflow: hidden;
            width: 768px;
            max-width: 100%;
            min-height: 480px;
            margin: auto;
        }

        .form-container {
            position: absolute;
            top: 0;
            height: 100%;
            transition: all 0.6s ease-in-out;
        }

        .sign-in-container {
            left: 0;
            width: 50%;
            z-index: 2;
        }

        .sign-up-container {
            left: 0;
            width: 50%;
            opacity: 0;
            z-index: 1;
        }

        /* Hiệu ứng khi active class đăng ký */
        .auth-container.right-panel-active .sign-in-container {
            transform: translateX(100%);
        }

        .auth-container.right-panel-active .sign-up-container {
            transform: translateX(100%);
            opacity: 1;
            z-index: 5;
            animation: show 0.6s;
        }

        @@keyframes show {
            0%, 49.99%

        {
            opacity: 0;
            z-index: 1;
        }

        50%, 100% {
            opacity: 1;
            z-index: 5;
        }

        }

        /* Overlay (Phần màu đỏ) */
        .overlay-container {
            position: absolute;
            top: 0;
            left: 50%;
            width: 50%;
            height: 100%;
            overflow: hidden;
            transition: transform 0.6s ease-in-out;
            z-index: 100;
        }

        .auth-container.right-panel-active .overlay-container {
            transform: translateX(-100%);
        }

        .overlay {
            background: #8b0000; /* Màu đỏ Manwah */
            background: linear-gradient(to right, #c0392b, #8b0000);
            color: #FFFFFF;
            position: relative;
            left: -100%;
            height: 100%;
            width: 200%;
            transform: translateX(0);
            transition: transform 0.6s ease-in-out;
        }

        .auth-container.right-panel-active .overlay {
            transform: translateX(50%);
        }

        .overlay-panel {
            position: absolute;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            padding: 0 40px;
            text-align: center;
            top: 0;
            height: 100%;
            width: 50%;
            transition: transform 0.6s ease-in-out;
        }

        .overlay-left {
            transform: translateX(-20%);
        }

        .auth-container.right-panel-active .overlay-left {
            transform: translateX(0);
        }

        .overlay-right {
            right: 0;
            transform: translateX(0);
        }

        .auth-container.right-panel-active .overlay-right {
            transform: translateX(20%);
        }

        /* Style input & button */
        .form-container form {
            background-color: #FFFFFF;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            padding: 0 50px;
            height: 100%;
        }

        input {
            background-color: #eee;
            border: none;
            padding: 12px 15px;
            margin: 8px 0;
            width: 100%;
            border-radius: 5px;
        }

        .btn-auth {
            border-radius: 20px;
            border: 1px solid #8b0000;
            background-color: #8b0000;
            color: #FFFFFF;
            font-size: 12px;
            font-weight: bold;
            padding: 12px 45px;
            letter-spacing: 1px;
            text-transform: uppercase;
            transition: transform 80ms ease-in;
            margin-top: 10px;
        }

        button.ghost {
            background-color: transparent;
            border-color: #FFFFFF;
        }
    </style>
}

@section Scripts {
    <script>
        const signUpButton = document.getElementById('signUp');
        const signInButton = document.getElementById('signIn');
        const container = document.getElementById('auth-container');

        signUpButton.addEventListener('click', () => {
            container.classList.add("right-panel-active");
        });

        signInButton.addEventListener('click', () => {
            container.classList.remove("right-panel-active");
        });
    </script>
    <partial name="_ValidationScriptsPartial" />
}