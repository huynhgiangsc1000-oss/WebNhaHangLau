@model DoAnCoSo.Models.Booking
@{
    ViewData["Title"] = "Thanh toán tiền cọc";
    decimal depositAmount = Model.TotalAmount * 0.3m;
    if (depositAmount < 30000) depositAmount = 30000;
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-danger text-white text-center py-4 rounded-top-4">
                    <h4 class="mb-0 fw-bold"><i class="fas fa-credit-card"></i> THANH TOÁN TIỀN CỌC GIỮ BÀN</h4>
                </div>
                <div class="card-body p-4 p-md-5">
                    <div class="alert alert-warning text-center fw-bold">
                        <i class="fas fa-exclamation-triangle"></i> Đơn của bạn có chọn trước menu thực đơn, vui lòng thanh toán đặt cọc trước 30% để hoàn tất giữ chỗ.
                    </div>

                    <div class="row mt-4 align-items-center">
                        <div class="col-md-6 border-end text-center mb-4 mb-md-0">
                            <h5 class="text-primary fw-bold mb-3">Thanh toán qua Ví điện tử</h5>
                            <img src="https://vnpay.vn/s1/statics.vnpay.vn/2023/9/06ncktiwd6dc1694418196384.png" alt="VNPAY" class="img-fluid p-2" style="max-width: 200px;" />
                            <div class="mt-3 small text-muted">
                                Hệ thống hỗ trợ thanh toán an toàn và tiện lợi qua cổng thanh toán VNPAY (Thẻ ATM, Visa, MasterCard, QR Code).
                            </div>
                        </div>
                        <div class="col-md-6 ps-md-4">
                            <h5 class="fw-bold mb-3 border-bottom pb-2">Thông tin đặt bàn</h5>
                            <p class="mb-2">Khách hàng: <strong>@Model.FullName</strong></p>
                            <p class="mb-2">SĐT: <strong>@Model.PhoneNumber</strong></p>
                            <p class="mb-2">Thời gian: <strong>@Model.BookingDate.ToString("dd/MM/yyyy HH:mm")</strong></p>
                            @if (!string.IsNullOrEmpty(Model.DiscountCode))
                            {
                                <p class="mb-2">Mã ưu đãi: <strong class="text-success">@Model.DiscountCode</strong></p>
                            }
                            <p class="mb-2">Giá trị thanh toán: <strong class="text-dark">@Model.TotalAmount.ToString("N0")đ</strong></p>
                            
                            <div class="bg-light p-3 rounded mt-4 text-center border">
                                <span class="d-block mb-1 text-muted">Số tiền cần đặt cọc (30%)</span>
                                <h3 class="text-danger fw-bold mb-0">@depositAmount.ToString("N0")đ</h3>
                            </div>
                        </div>
                    </div>

                    <div class="text-center mt-5 border-top pt-4">
                        <p class="text-muted small mb-3">Nhấn nút bên dưới để chuyển sang Cổng thanh toán VNPAY. Sau khi thanh toán thành công, hệ thống sẽ gửi vé điện tử (Check-in QR) vào email của bạn.</p>
                        <form method="post" asp-action="PayDepositVnpay" asp-route-id="@Model.BookingId">
                            <button type="submit" class="btn btn-primary btn-lg px-5 rounded-pill shadow-sm fw-bold">
                                <i class="fas fa-wallet"></i> THANH TOÁN QUA VNPAY
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
