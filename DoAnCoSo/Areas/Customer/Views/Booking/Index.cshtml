@model DoAnCoSo.Models.Booking
@{
    ViewData["Title"] = "Đặt bàn trước";
}

<div class="container mt-5 mb-5">
    <div class="card shadow-sm border-0 rounded-lg mx-auto" style="max-width: 800px;">
        <div class="card-body p-4 p-md-5">
            <h3 class="text-center text-danger fw-bold mb-4">ĐẶT BÀN TRỰC TUYẾN</h3>

            <form asp-action="Create" method="post" class="needs-validation" novalidate>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FullName" class="form-label fw-bold">Họ và Tên</label>
                        <input asp-for="FullName" class="form-control" placeholder="Nhập tên của bạn" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label fw-bold">Email nhận mã</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="example@gmail.com" required />
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label fw-bold">Số điện thoại</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="090x xxx xxx" required />
                </div>
                <div class="row">
                    <div class="col-md-7 mb-3">
                        <label class="form-label fw-bold">Ngày & Giờ đến</label>
                        <input type="text" id="bookingDatePicker" name="BookingDate" class="form-control" placeholder="Chọn ngày giờ" required />
                    </div>
                    <div class="col-md-5 mb-3">
                        <label asp-for="GuestCount" class="form-label fw-bold">Số lượng khách</label>
                        <input asp-for="GuestCount" type="number" class="form-control" min="1" value="2" required />
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="Note" class="form-label fw-bold">Ghi chú</label>
                    <textarea asp-for="Note" class="form-control" rows="2"></textarea>
                </div>
                <button type="submit" class="btn btn-danger w-100 py-3 fw-bold shadow">GỬI YÊU CẦU ĐẶT BÀN</button>
            </form>
        </div>
    </div>
</div>