@model DoAnCoSo.Models.Booking
@{
    ViewData["Title"] = "Đặt bàn trực tuyến";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <style>
        body {
            background-color: #fcfcf9;
        }

        .custom-card {
            background: #fff;
            border-radius: 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            padding: 25px;
            height: 100%;
        }

        .section-title {
            font-weight: 800;
            color: #a32a2a;
            margin-bottom: 20px;
            border-bottom: 2px solid #f8f9fa;
            padding-bottom: 10px;
        }

        .form-control {
            background: #f8f9fa;
            border: 1px solid #eee;
            border-radius: 10px;
            padding: 10px;
        }

        .btn-submit {
            background: #a32a2a;
            color: #fff;
            border-radius: 10px;
            padding: 15px;
            font-weight: bold;
            width: 100%;
            border: none;
        }

        .menu-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            max-height: 500px;
            overflow-y: auto;
        }

        .menu-item-box {
            border: 1px solid #eee;
            border-radius: 15px;
            padding: 10px;
            text-align: center;
        }

            .menu-item-box img {
                width: 100%;
                height: 100px;
                object-fit: cover;
                border-radius: 10px;
                margin-bottom: 8px;
            }

        .cart-item-img {
            width: 50px;
            height: 50px;
            object-fit: cover;
            border-radius: 8px;
        }
    </style>
}

<div class="container-fluid px-4 mt-4">
    <form id="bookingForm" method="post" asp-area="Customer" asp-controller="Booking" asp-action="Create">
        <!-- Input ẩn để chứa dữ liệu giỏ hàng gửi về Controller -->
        <input type="hidden" name="CartDetails" id="cartJsonInput" />

        <div class="row g-4">
            <div class="col-md-3">
                <div class="custom-card">
                    <h5 class="section-title">📅 THÔNG TIN</h5>
                    <div class="mb-3"><input asp-for="FullName" class="form-control" placeholder="Họ và tên" required /></div>
                    <div class="mb-3"><input asp-for="PhoneNumber" class="form-control" placeholder="Số điện thoại" required /></div>
                    <div class="mb-3"><input asp-for="GuestCount" type="number" class="form-control" placeholder="Số khách" /></div>
                    <div class="mb-3"><input type="text" id="bookingDatePicker" name="BookingDate" class="form-control" placeholder="Chọn ngày giờ" required /></div>
                    <div class="mb-3"><textarea name="Note" class="form-control" placeholder="Ghi chú..." rows="2"></textarea></div>
                    <div class="mb-3"><input type="text" id="voucherCode" class="form-control" placeholder="Mã giảm giá (VD: GIAM10)" oninput="renderCart()" /></div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="custom-card">
                    <h5 class="section-title">📋 THỰC ĐƠN</h5>
                    <input type="text" id="searchInput" class="form-control mb-2" placeholder="🔍 Tìm món ăn..." onkeyup="filterMenu()" />
                    <select id="priceFilter" class="form-control mb-3" onchange="filterMenu()">
                        <option value="0">Tất cả giá</option>
                        <option value="100000">Dưới 100.000đ</option>
                        <option value="200000">Dưới 200.000đ</option>
                    </select>
                    <div class="menu-grid" id="menuGrid">
                        @foreach (var p in (List<DoAnCoSo.Models.Product>)ViewBag.Products)
                        {
                            string imgPath = string.IsNullOrEmpty(p.ImagePath) ? "default.jpg" : p.ImagePath;
                            <div class="menu-item-box product-item" data-name="@p.ProductName.ToLower()" data-price="@p.Price">
                                <img src="/images/@imgPath" onerror="this.src='/images/default.jpg'" />
                                <div class="small fw-bold">@p.ProductName</div>
                                <div class="text-danger small">@string.Format("{0:N0}", p.Price)đ</div>
                                <button type="button" class="btn btn-sm btn-outline-danger mt-1 w-100"
                                        data-product-id="@p.ProductId"
                                        data-product-name="@p.ProductName"
                                        data-product-price="@p.Price"
                                        data-product-img="@imgPath"
                                        onclick="addToCart(this.dataset.productId, this.dataset.productName, this.dataset.productPrice, this.dataset.productImg)">
                                    Thêm
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="custom-card">
                    <h5 class="section-title">🛒 GIỎ HÀNG</h5>
                    <div id="cartList" style="max-height: 300px; overflow-y: auto;"></div>
                    <div class="mt-3 border-top pt-2">
                        <div class="d-flex justify-content-between small"><span>Phí giữ bàn:</span> <b>30.000đ</b></div>
                        <div class="d-flex justify-content-between small"><span>Tiền món:</span> <b id="foodTotal">0đ</b></div>
                        <div class="d-flex justify-content-between small text-success"><span>Giảm giá:</span> <b id="discountAmount">0đ</b></div>
                        <div class="d-flex justify-content-between mt-2"><span>Đặt cọc (30%):</span> <b id="depositDisplay" class="text-primary">0đ</b></div>
                        <h5 class="mt-2 text-danger">Tổng thanh toán: <span id="finalTotal">30.000đ</span></h5>
                    </div>
                    <button type="submit" class="btn btn-submit mt-3">XÁC NHẬN ĐẶT BÀN</button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        // 1. Khởi tạo lịch
        flatpickr("#bookingDatePicker", {
            enableTime: true,
            dateFormat: "d/m/Y H:i",
            time_24hr: true,
            minDate: "today"
        });

        let cart = [];

        function filterMenu() {
            let search = document.getElementById('searchInput').value.toLowerCase();
            let limit = parseInt(document.getElementById('priceFilter').value);
            document.querySelectorAll('.product-item').forEach(item => {
                let name = item.getAttribute('data-name');
                let price = parseInt(item.getAttribute('data-price'));
                item.style.display = (name.includes(search) && (limit === 0 || price <= limit)) ? 'block' : 'none';
            });
        }

        function addToCart(id, name, price, img) {
            let item = cart.find(i => i.id == id);
            if (item) item.qty++;
            else cart.push({ id, name, price: parseInt(price), image: img, qty: 1 });
            renderCart();
        }
            function renderCart() {
        let list = document.getElementById('cartList');
        list.innerHTML = '';
        let foodTotal = 0;

        cart.forEach(i => {
            foodTotal += (i.price * i.qty);

            // Logic kiểm tra ảnh: nếu tên file trống hoặc null, dùng default.jpg
            let imgPath = (i.image && i.image !== "null" && i.image.trim() !== "") ? i.image : 'default.jpg';

            list.innerHTML += `
                <div class="cart-item mb-2 d-flex align-items-center">
                    <img src="/images/${imgPath}"
                         class="cart-item-img"
                         onerror="this.src='/images/default.jpg'">
                    <div class="ms-2">
                        <div class="small fw-bold">${i.name}</div>
                        <div class="text-danger small">${i.price.toLocaleString()}đ x ${i.qty}</div>
                    </div>
                </div>`;
        });

            // Tính tiền
            let voucher = document.getElementById('voucherCode').value;
            let discount = (voucher === "GIAM10") ? 10000 : 0;
            let baseTotal = 30000 + foodTotal;
            let amountAfterDiscount = Math.max(0, baseTotal - discount);
            let deposit = amountAfterDiscount * 0.3;

            document.getElementById('foodTotal').innerText = foodTotal.toLocaleString() + 'đ';
            document.getElementById('discountAmount').innerText = "-" + discount.toLocaleString() + 'đ';
            document.getElementById('depositDisplay').innerText = deposit.toLocaleString() + 'đ';
            document.getElementById('finalTotal').innerText = amountAfterDiscount.toLocaleString() + 'đ';

            // Cập nhật dữ liệu vào input ẩn
            document.getElementById('cartJsonInput').value = JSON.stringify(cart);
        }
    </script>
}