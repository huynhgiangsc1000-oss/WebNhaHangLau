@model DoAnCoSo.Models.Booking
@{
    ViewData["Title"] = "Đặt bàn trực tuyến";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" integrity="sha512-9usAa10IRO0HhonpyAIVpjrylPvoDwiPUiKdWk5t3PyolY1cOd4DSE0Ga+ri4AuTroPR5aQvXU9xC6qOPnzFeg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <style>
        body { background-color: #fcfcf9; }
        .wizard-container { max-width: 900px; margin: 0 auto; background: #fff; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); overflow: hidden; }
        .wizard-header { background: #a32a2a; color: white; padding: 20px; text-align: center; }
        .wizard-steps { display: flex; justify-content: space-between; padding: 20px; background: #f8f9fa; border-bottom: 1px solid #eee; }
        .step-item { text-align: center; flex: 1; position: relative; color: #ccc; font-weight: bold; }
        .step-item.active { color: #a32a2a; }
        .step-item.completed { color: #28a745; }
        .wizard-body { padding: 30px; }
        .wizard-step { display: none; }
        .wizard-step.active { display: block; animation: fadeIn 0.3s; }
        @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        
        /* Step 2: Tables */
        .table-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 15px; }
        .table-card { border: 2px solid #eee; border-radius: 15px; padding: 15px; text-align: center; cursor: pointer; transition: 0.2s; }
        .table-card:hover { border-color: #a32a2a; }
        .table-card.selected { background: #a32a2a; color: white; border-color: #a32a2a; }
        .table-card i { font-size: 2rem; margin-bottom: 10px; }
        
        /* Step 3: Menu */
        .menu-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; max-height: 500px; overflow-y: auto; padding: 10px; }
        .menu-item { border: 1px solid #eee; border-radius: 15px; padding: 10px; text-align: center; transition: 0.2s; }
        .menu-item:hover { box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
        .menu-item img { width: 100%; height: 120px; object-fit: cover; border-radius: 10px; margin-bottom: 10px; }
        .btn-add { background: #fff; color: #a32a2a; border: 1px solid #a32a2a; border-radius: 5px; width: 100%; padding: 5px; margin-top: 10px; transition: 0.2s; }
        .btn-add:hover { background: #a32a2a; color: white; }
        
        .floating-cart { position: fixed; bottom: 20px; right: 20px; background: #a32a2a; color: white; padding: 15px 25px; border-radius: 30px; box-shadow: 0 5px 15px rgba(163, 42, 42, 0.4); cursor: pointer; z-index: 1000; font-weight: bold; display: none; }
    </style>
}

<div class="container mt-4 mb-5">
    <div class="wizard-container">
        <div class="wizard-header">
            <h3 class="mb-0"><i class="fas fa-utensils"></i> ĐẶT BÀN NHÀ HÀNG</h3>
        </div>
        <div class="wizard-steps">
            <div class="step-item active" id="indicator-1">1. Thông tin</div>
            <div class="step-item" id="indicator-2">2. Chọn bàn</div>
            <div class="step-item" id="indicator-3">3. Chọn món</div>
            <div class="step-item" id="indicator-4">4. Xác nhận</div>
        </div>

        <form id="bookingForm" method="post" asp-area="Customer" asp-controller="Booking" asp-action="Create">
            <input type="hidden" name="CartDetails" id="cartJsonInput" />
            <input type="hidden" asp-for="TableId" id="selectedTableId" />

            <div class="wizard-body">
                <!-- STEP 1 -->
                <div class="wizard-step active" id="step-1">
                    <h5 class="mb-4 text-center text-danger fw-bold">Thông tin đặt bàn</h5>
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Ngày và Giờ <span class="text-danger">*</span></label>
                            <input type="text" id="bookingDatePicker" name="BookingDate" value="@Model.BookingDate.ToString("yyyy-MM-dd HH:mm")" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Số lượng khách <span class="text-danger">*</span></label>
                            <input asp-for="GuestCount" type="number" id="guestCountInput" class="form-control" min="1" max="50" required />
                        </div>
                    </div>
                    <div class="text-end mt-4">
                        <button type="button" class="btn btn-danger px-4 py-2 rounded-pill" onclick="goToStep(2)">Tiếp tục <i class="fas fa-arrow-right"></i></button>
                    </div>
                </div>

                <!-- STEP 2 -->
                <div class="wizard-step" id="step-2">
                    <h5 class="mb-4 text-center text-danger fw-bold">Chọn Bàn</h5>
                    <div id="tableLoading" class="text-center text-muted"><i class="fas fa-spinner fa-spin"></i> Đang tìm bàn trống...</div>
                    <div id="tableGrid" class="table-grid"></div>
                    <div class="text-danger mt-2 text-center" id="tableError" style="display:none;">Vui lòng chọn 1 bàn để tiếp tục!</div>
                    
                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary px-4 py-2 rounded-pill" onclick="goToStep(1)"><i class="fas fa-arrow-left"></i> Quay lại</button>
                        <button type="button" class="btn btn-danger px-4 py-2 rounded-pill" onclick="validateStep2()">Tiếp tục <i class="fas fa-arrow-right"></i></button>
                    </div>
                </div>

                <!-- STEP 3 -->
                <div class="wizard-step" id="step-3">
                    <h5 class="mb-4 text-center text-danger fw-bold">Chọn món trước (Không bắt buộc)</h5>
                    <div class="menu-grid">
                        @foreach (var p in (List<DoAnCoSo.Models.Product>)ViewBag.Products)
                        {
                            string imgPath = string.IsNullOrEmpty(p.ImagePath) ? "default.jpg" : p.ImagePath;
                            <div class="menu-item">
                                <img src="/images/@imgPath" onerror="this.src='/images/default.jpg'" />
                                <div class="fw-bold small">@p.ProductName</div>
                                <div class="text-danger fw-bold">@string.Format("{0:N0}", p.Price)đ</div>
                                <button type="button" class="btn-add" onclick="addToCart(@p.ProductId, '@p.ProductName', @p.Price)">
                                    <i class="fas fa-plus"></i> Thêm
                                </button>
                            </div>
                        }
                    </div>
                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary px-4 py-2 rounded-pill" onclick="goToStep(2)"><i class="fas fa-arrow-left"></i> Quay lại</button>
                        <button type="button" class="btn btn-danger px-4 py-2 rounded-pill" onclick="goToStep(4)">Tiếp tục <i class="fas fa-arrow-right"></i></button>
                    </div>
                </div>

                <!-- STEP 4 -->
                <div class="wizard-step" id="step-4">
                    <h5 class="mb-4 text-center text-danger fw-bold">Thông tin liên hệ & Hoàn tất</h5>
                    <div class="row g-4">
                        <div class="col-md-7">
                            <div class="mb-3">
                                <label class="form-label">Họ và tên <span class="text-danger">*</span></label>
                                <input asp-for="FullName" class="form-control" required />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Số điện thoại <span class="text-danger">*</span></label>
                                <input asp-for="PhoneNumber" class="form-control" required />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email <span class="text-danger">*</span></label>
                                <input asp-for="Email" type="email" class="form-control" required />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Ghi chú</label>
                                <textarea asp-for="Note" class="form-control" rows="2"></textarea>
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="card bg-light border-0 shadow-sm rounded-4">
                                <div class="card-body p-4">
                                    <h6 class="fw-bold mb-3 text-center">TÓM TẮT ĐẶT BÀN</h6>
                                    <ul id="checkoutCartList" class="list-unstyled mb-3 small border-bottom pb-2"></ul>
                                    
                                    <!-- Phần Nhập mã giảm giá -->
                                    <div class="d-flex justify-content-between mb-2 align-items-end">
                                        <label class="form-label mb-0 small fw-bold">Mã giảm giá</label>
                                        <button type="button" class="btn btn-link btn-sm p-0 text-danger text-decoration-none" onclick="openPromoModal()"><i class="fas fa-gift"></i> Chọn Ưu đãi</button>
                                    </div>
                                    <div class="input-group mb-3">
                                        <input type="text" asp-for="DiscountCode" id="discountCodeInput" class="form-control form-control-sm text-uppercase" placeholder="Nhập mã giảm giá (Nếu có)">
                                        <button class="btn btn-outline-danger btn-sm" type="button" onclick="applyDiscount()">Áp dụng</button>
                                    </div>
                                    <div id="discountMessage" class="small mb-3 fw-bold"></div>

                                    <div class="d-flex justify-content-between mb-2 small text-muted"><span>Phí giữ bàn (Mặc định):</span> <b>30.000đ</b></div>
                                    <div class="d-flex justify-content-between mb-2 small text-muted"><span>Tiền món:</span> <b id="checkoutFoodTotal">0đ</b></div>
                                    <div class="d-flex justify-content-between mb-2 small text-success" id="discountRow" style="display:none !important;"><span>Giảm giá:</span> <b id="checkoutDiscount">-0đ</b></div>
                                    
                                    <div class="d-flex justify-content-between text-danger fw-bold fs-5 mt-3 pt-2 border-top">
                                        <span>Cần đặt cọc (30%):</span> <span id="checkoutDeposit">30.000đ</span>
                                    </div>
                                    <div class="text-center mt-3">
                                        <p class="text-muted small mb-0"><i class="fas fa-info-circle"></i> Vui lòng thanh toán số tiền cọc qua mã QR ở màn hình tiếp theo.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between mt-4">
                        <button type="button" class="btn btn-outline-secondary px-4 py-2 rounded-pill" onclick="goToStep(3)"><i class="fas fa-arrow-left"></i> Quay lại</button>
                        <button type="submit" class="btn btn-danger px-5 py-2 fw-bold rounded-pill shadow"><i class="fas fa-check-circle"></i> XÁC NHẬN ĐẶT BÀN</button>
                    </div>
                </div>

            </div>
        </form>
    </div>
</div>

<!-- Offcanvas Cart -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="cartOffcanvas">
  <div class="offcanvas-header bg-danger text-white">
    <h5 class="offcanvas-title"><i class="fas fa-shopping-cart"></i> Giỏ hàng của bạn</h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div class="offcanvas-body">
    <div id="cartList" class="mb-4"></div>
    <div class="border-top pt-3">
        <h5 class="text-danger d-flex justify-content-between fw-bold">Tổng tiền món: <span id="cartTotal">0đ</span></h5>
    </div>
  </div>
</div>

<div class="floating-cart" id="floatingCart" data-bs-toggle="offcanvas" data-bs-target="#cartOffcanvas">
    <i class="fas fa-shopping-cart"></i> <span id="cartCount">0</span> món - <span id="cartFloatingTotal">0đ</span>
</div>

<!-- Promo Modal -->
<div class="modal fade" id="promoModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="fas fa-tags"></i> Chọn mã giảm giá</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body bg-light" id="promoModalBody">
                <div class="text-center text-muted"><i class="fas fa-spinner fa-spin"></i> Đang tải...</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        let currentStep = 1;
        let cart = [];
        let selectedTable = null;
        let currentDiscount = 0; // Thêm biến lưu phần trăm giảm giá

        function openPromoModal() {
            let modal = new bootstrap.Modal(document.getElementById('promoModal'));
            modal.show();
            
            fetch('/Customer/Booking/GetActivePromotions')
                .then(res => res.json())
                .then(data => {
                    let html = '';
                    if (data.length === 0) {
                        html = '<div class="text-center text-muted p-4">Không có mã giảm giá nào phù hợp lúc này.</div>';
                    } else {
                        data.forEach(p => {
                            html += `
                                <div class="card mb-3 border-0 shadow-sm">
                                    <div class="card-body d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="fw-bold text-danger mb-1">${p.title}</h6>
                                            <div class="small text-muted mb-1">${p.description || ''}</div>
                                            <div class="small fw-bold">Mã: <span class="text-dark">${p.couponCode}</span> <span class="badge bg-danger ms-1">-${p.discountValue}%</span></div>
                                            <div class="small text-muted" style="font-size:11px;">HSD: ${p.endDate}</div>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-danger" onclick="selectPromo('${p.couponCode}')">Áp dụng</button>
                                    </div>
                                </div>
                            `;
                        });
                    }
                    document.getElementById('promoModalBody').innerHTML = html;
                })
                .catch(err => {
                    document.getElementById('promoModalBody').innerHTML = '<div class="text-danger text-center p-3">Lỗi tải dữ liệu.</div>';
                });
        }

        function selectPromo(code) {
            document.getElementById('discountCodeInput').value = code;
            bootstrap.Modal.getInstance(document.getElementById('promoModal')).hide();
            applyDiscount();
        }

        flatpickr("#bookingDatePicker", {
            enableTime: true,
            dateFormat: "Y-m-d H:i",
            time_24hr: true,
            minDate: "today"
        });

        function goToStep(step) {
            if (step === 2 && currentStep === 1) {
                // Validate step 1
                let date = document.getElementById('bookingDatePicker').value;
                let guests = document.getElementById('guestCountInput').value;
                if (!date || !guests) {
                    alert('Vui lòng chọn Ngày giờ và Số lượng khách!');
                    return;
                }
                loadTables(date, guests);
            }

            document.querySelectorAll('.wizard-step').forEach(el => el.classList.remove('active'));
            document.getElementById('step-' + step).classList.add('active');

            document.querySelectorAll('.step-item').forEach((el, index) => {
                el.classList.remove('active', 'completed');
                if (index + 1 < step) el.classList.add('completed');
                if (index + 1 === step) el.classList.add('active');
            });

            currentStep = step;
            
            if (step === 3) {
                document.getElementById('floatingCart').style.display = 'block';
            } else {
                document.getElementById('floatingCart').style.display = 'none';
            }

            if (step === 4) {
                renderCheckoutCart();
            }
        }

        function loadTables(date, guests) {
            document.getElementById('tableLoading').style.display = 'block';
            document.getElementById('tableGrid').innerHTML = '';
            selectedTable = null;
            document.getElementById('selectedTableId').value = '';

            fetch(`/Customer/Booking/GetAvailableTables?bookingDate=${encodeURIComponent(date)}&guestCount=${guests}`)
                .then(res => res.json())
                .then(data => {
                    document.getElementById('tableLoading').style.display = 'none';
                    let grid = document.getElementById('tableGrid');
                    if (data.length === 0) {
                        grid.innerHTML = '<div class="col-12 text-center text-danger fw-bold p-4">Rất tiếc, hiện tại không tìm thấy bàn trống phù hợp cho thời gian và số người này! Vui lòng chọn thời gian khác.</div>';
                        return;
                    }

                    data.forEach(t => {
                        let div = document.createElement('div');
                        div.className = 'table-card shadow-sm';
                        div.innerHTML = `<i class="fas fa-chair"></i><br/><b class="text-dark">${t.tableName}</b><br/><small class="text-muted">Tối đa ${t.capacity} người</small>`;
                        div.onclick = function() {
                            document.querySelectorAll('.table-card').forEach(c => c.classList.remove('selected'));
                            this.classList.add('selected');
                            selectedTable = t.tableId;
                            document.getElementById('selectedTableId').value = t.tableId;
                            document.getElementById('tableError').style.display = 'none';
                        };
                        grid.appendChild(div);
                    });
                })
                .catch(err => {
                    document.getElementById('tableLoading').innerHTML = '<div class="text-danger">Đã có lỗi xảy ra khi tải danh sách bàn.</div>';
                });
        }

        function validateStep2() {
            if (!selectedTable) {
                document.getElementById('tableError').style.display = 'block';
                return;
            }
            goToStep(3);
        }

        function addToCart(id, name, price) {
            let item = cart.find(i => i.id === id);
            if (item) item.qty++;
            else cart.push({ id, name, price: parseInt(price), qty: 1 });
            renderCart();
            
            // Show offcanvas automatically on first add
            if(cart.length === 1 && cart[0].qty === 1) {
                let offcanvas = new bootstrap.Offcanvas(document.getElementById('cartOffcanvas'));
                offcanvas.show();
            }
        }

        function updateQty(id, change) {
            let index = cart.findIndex(i => i.id === id);
            if (index > -1) {
                cart[index].qty += change;
                if (cart[index].qty <= 0) cart.splice(index, 1);
            }
            renderCart();
        }

        function renderCart() {
            let list = document.getElementById('cartList');
            list.innerHTML = '';
            let total = 0;
            let count = 0;

            cart.forEach(i => {
                total += (i.price * i.qty);
                count += i.qty;
                list.innerHTML += `
                    <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                        <div>
                            <div class="fw-bold text-dark">${i.name}</div>
                            <div class="text-danger small fw-bold">${i.price.toLocaleString()}đ</div>
                        </div>
                        <div class="d-flex align-items-center">
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="updateQty(${i.id}, -1)"><i class="fas fa-minus"></i></button>
                            <span class="mx-3 fw-bold">${i.qty}</span>
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="updateQty(${i.id}, 1)"><i class="fas fa-plus"></i></button>
                        </div>
                    </div>`;
            });

            if(cart.length === 0) {
                list.innerHTML = '<div class="text-center text-muted p-3">Chưa có món nào</div>';
            }

            document.getElementById('cartTotal').innerText = total.toLocaleString() + 'đ';
            document.getElementById('cartFloatingTotal').innerText = total.toLocaleString() + 'đ';
            document.getElementById('cartCount').innerText = count;
            document.getElementById('cartJsonInput').value = JSON.stringify(cart);
        }

        function renderCheckoutCart() {
            let list = document.getElementById('checkoutCartList');
            list.innerHTML = '';
            let total = 0;
            cart.forEach(i => {
                total += (i.price * i.qty);
                list.innerHTML += `<li class="d-flex justify-content-between mb-2"><span><b>${i.qty}x</b> ${i.name}</span> <span>${(i.price * i.qty).toLocaleString()}đ</span></li>`;
            });
            
            if (cart.length === 0) {
                list.innerHTML = '<li class="text-muted">Chưa chọn món trước</li>';
            }

            document.getElementById('checkoutFoodTotal').innerText = total.toLocaleString() + 'đ';
            
            // Tính giảm giá
            let discountAmount = total * (currentDiscount / 100);
            if(discountAmount > 0) {
                document.getElementById('discountRow').style.setProperty('display', 'flex', 'important');
                document.getElementById('checkoutDiscount').innerText = '-' + discountAmount.toLocaleString() + 'đ';
            } else {
                document.getElementById('discountRow').style.setProperty('display', 'none', 'important');
            }

            let finalTotal = total - discountAmount;
            let deposit = Math.max(30000, finalTotal * 0.3);
            document.getElementById('checkoutDeposit').innerText = deposit.toLocaleString() + 'đ';
        }

        function applyDiscount() {
            let code = document.getElementById('discountCodeInput').value.trim();
            let msgBox = document.getElementById('discountMessage');
            
            if(!code) {
                msgBox.innerHTML = '<span class="text-danger">Vui lòng nhập mã giảm giá</span>';
                return;
            }

            fetch(`/Customer/Booking/CheckDiscountCode?code=${encodeURIComponent(code)}`)
                .then(res => res.json())
                .then(data => {
                    if(data.success) {
                        msgBox.innerHTML = `<span class="text-success"><i class="fas fa-check-circle"></i> ${data.message}</span>`;
                        currentDiscount = data.discount;
                        renderCheckoutCart(); // Tính lại tiền
                    } else {
                        msgBox.innerHTML = `<span class="text-danger"><i class="fas fa-exclamation-circle"></i> ${data.message}</span>`;
                        currentDiscount = 0;
                        renderCheckoutCart();
                    }
                })
                .catch(err => {
                    msgBox.innerHTML = '<span class="text-danger">Lỗi kết nối</span>';
                });
        }
    </script>
}