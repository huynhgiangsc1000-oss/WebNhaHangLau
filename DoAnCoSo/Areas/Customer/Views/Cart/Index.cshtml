@using Microsoft.AspNetCore.Http
@model IEnumerable<DoAnCoSo.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng";
    Layout = "_Layout";
    var displayTableName = Model.FirstOrDefault()?.Table?.TableName ?? ViewBag.TableName ?? "N/A";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">
            <i class="fas fa-shopping-cart text-danger"></i> Giỏ hàng của:
            <span class="badge rounded-pill bg-danger shadow-sm px-3">
                <i class="fas fa-chair me-1"></i> @displayTableName
            </span>
        </h2>
        <a href="@Url.Action("Index", "Menu")" class="btn btn-outline-primary rounded-pill px-4 shadow-sm">
            <i class="fas fa-chevron-left me-2"></i>Thêm món khác
        </a>
    </div>

    <div id="cart-container" class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4 py-3">Món ăn</th>
                                <th class="text-center py-3">Giá</th>
                                <th class="text-center py-3" style="width: 150px;">Số lượng</th>
                                <th class="text-end py-3">Thành tiền</th>
                                <th class="text-center py-3 pe-4">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="position-relative">
                                                <img src="~/images/@item.Product.ImagePath" class="rounded-3 shadow-sm"
                                                     style="width: 70px; height: 70px; object-fit: cover;"
                                                     onerror="this.src='/images/no-image.png'" />
                                            </div>
                                            <div class="ms-3">
                                                <h6 class="mb-0 fw-bold">@item.Product.ProductName</h6>
                                                <small class="text-muted">Đơn giá: @item.Product.Price.ToString("N0") đ</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center fw-medium">@item.Product.Price.ToString("N0") đ</td>
                                    <td>
                                        @* BỘ NÚT TĂNG GIẢM SỐ LƯỢNG *@
                                        <div class="d-flex align-items-center justify-content-center border rounded-pill p-1" style="max-width: 120px; margin: 0 auto; background: #f8f9fa;">
                                            <button class="btn btn-sm btn-white border-0 rounded-circle shadow-none p-1"
                                                    onclick="updateQuantity(@item.ProductId, -1)">
                                                <i class="fas fa-minus text-muted" style="font-size: 0.8rem;"></i>
                                            </button>

                                            <span class="mx-3 fw-bold" style="min-width: 20px; text-align: center;">@item.Quantity</span>

                                            <button class="btn btn-sm btn-white border-0 rounded-circle shadow-none p-1"
                                                    onclick="updateQuantity(@item.ProductId, 1)">
                                                <i class="fas fa-plus text-danger" style="font-size: 0.8rem;"></i>
                                            </button>
                                        </div>
                                    </td>
                                    <td class="text-end text-danger fw-bold">@((item.Quantity * item.Product.Price).ToString("N0")) đ</td>
                                    <td class="text-center pe-4">
                                        @* NÚT XÓA *@
                                        <button class="btn btn-sm btn-light rounded-circle hover-danger shadow-sm"
                                                onclick="removeItem(@item.ProductId)"
                                                style="width: 35px; height: 35px;">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-between align-items-center p-4 bg-light border-top rounded-bottom-4">
                    <div>
                        <p class="text-muted mb-1 small text-uppercase fw-bold">Trạng thái bàn:</p>
                        <span class="text-success"><i class="fas fa-circle fa-xs me-1"></i> Đang chọn món</span>
                    </div>
                    <div class="text-end d-flex align-items-center">
                        <div class="me-4">
                            <span class="text-muted small d-block">TỔNG CỘNG:</span>
                            <span class="h3 text-danger fw-bold mb-0">@Model.Sum(x => x.Quantity * x.Product.Price).ToString("N0") đ</span>
                        </div>
                        <button onclick="confirmCheckout()" class="btn btn-danger btn-lg px-5 py-3 rounded-pill shadow fw-bold">
                            XÁC NHẬN ĐẶT MÓN
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <img src="https://cdn-icons-png.flaticon.com/512/11329/11329060.png" style="width: 150px; opacity: 0.5" class="mb-4">
                    <h4 class="text-muted fw-bold">Giỏ hàng của bạn đang trống</h4>
                    <p class="text-muted">Hãy chọn những món ăn ngon từ thực đơn nhé!</p>
                    <a href="@Url.Action("Index", "Menu")" class="btn btn-danger rounded-pill px-5 mt-2">Xem Menu ngay</a>
                </div>
            }
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

<style>
    .hover-danger:hover {
        background-color: #fff5f5 !important;
        color: #dc3545 !important;
        border-color: #dc3545 !important;
    }

    .table-hover tbody tr:hover {
        background-color: #fffafb;
    }

    .btn-white {
        background-color: white;
    }

        .btn-white:hover {
            background-color: #eee;
        }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function getCsrfToken() {
            return $('input[name="__RequestVerificationToken"]').val();
        }

        function updateQuantity(pId, change) {
            // Hiển thị loading nhẹ hoặc disable nút để tránh spam click
            $.ajax({
                url: '/Customer/Cart/UpdateQuantity',
                type: 'POST',
                data: {
                    productId: pId,
                    change: change,
                    "__RequestVerificationToken": getCsrfToken()
                },
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    }
                },
                error: function() {
                    console.error("Lỗi cập nhật số lượng");
                }
            });
        }

        function removeItem(productId) {
            Swal.fire({
                title: 'Xóa món ăn?',
                text: "Bạn có chắc muốn bỏ món này khỏi giỏ hàng?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                confirmButtonText: 'Đồng ý xóa',
                cancelButtonText: 'Hủy'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Customer/Cart/RemoveItem',
                        type: 'POST',
                        data: {
                            productId: productId,
                            "__RequestVerificationToken": getCsrfToken()
                        },
                        success: function (response) {
                            if (response.success) {
                                location.reload();
                            }
                        }
                    });
                }
            });
        }

              // 3. XÁC NHẬN ĐẶT MÓN (CHECKOUT)
        function confirmCheckout() {
            Swal.fire({
                title: 'Xác nhận đặt món?',
                text: "Yêu cầu của bạn sẽ được gửi trực tiếp đến nhà bếp!",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#198754',
                confirmButtonText: 'Đúng, đặt ngay!',
                cancelButtonText: 'Để tôi xem lại'
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        title: 'Đang gửi đơn hàng...',
                        allowOutsideClick: false,
                        didOpen: () => { Swal.showLoading() }
                    });

                    $.ajax({
                        url: '/Customer/Cart/Checkout',
                        type: 'POST',
                        data: {
                            "__RequestVerificationToken": getCsrfToken()
                        },
                        success: function (res) {
                            if (res.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Đặt món thành công!',
                                    text: 'Bếp đã nhận được đơn hàng của bạn.',
                                    timer: 2000,
                                    showConfirmButton: false
                                }).then(() => {
                                    // CHỖ THAY ĐỔI: Chuyển hướng sang trang chi tiết đơn hàng vừa tạo
                                    // Giả sử server trả về orderId trong res.orderId
                                    window.location.href = '/Customer/Order/OrderDetails/' + res.orderId;
                                });
                            } else {
                                Swal.fire('Thất bại', res.message, 'error');
                            }
                        }
                    });
                }
            });
        }
    </script>
}