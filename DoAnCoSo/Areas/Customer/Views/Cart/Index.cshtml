@using Microsoft.AspNetCore.Http
@model IEnumerable<DoAnCoSo.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng của bạn";
    Layout = "_Layout";
    var tableId = Context.Session.GetString("TableId") ?? Context.Request.Cookies["SavedTableId"];
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>
            <i class="fas fa-shopping-cart text-primary"></i> Giỏ hàng của bàn:
            <span class="badge bg-danger">@(string.IsNullOrEmpty(tableId) ? "Chưa chọn" : tableId)</span>
        </h2>
        <a href="@Url.Action("Index", "Menu")" class="btn btn-outline-primary shadow-sm">
            <i class="fas fa-plus"></i> Thêm món khác
        </a>
    </div>

    <div id="cart-container" class="card shadow-sm border-0">
        <div class="card-body p-4">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="bg-light">
                            <tr>
                                <th>Món ăn</th>
                                <th class="text-center">Giá</th>
                                <th class="text-center" style="width: 150px;">Số lượng</th>
                                <th class="text-end">Thành tiền</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="~/images/@item.Product.ImagePath" class="rounded mr-3"
                                                 style="width: 60px; height: 60px; object-fit: cover;" onerror="this.src='/images/no-image.png'" />
                                            <span class="fw-bold ms-2">@item.Product.ProductName</span>
                                        </div>
                                    </td>
                                    <td class="text-center">@item.Product.Price.ToString("N0") đ</td>
                                    <td>
                                        <div class="input-group input-group-sm justify-content-center">
                                            <button class="btn btn-outline-secondary" onclick="updateQuantity(@item.ProductId, -1)">-</button>
                                            <input type="text" class="form-control text-center" value="@item.Quantity" style="max-width: 40px;" readonly>
                                            <button class="btn btn-outline-secondary" onclick="updateQuantity(@item.ProductId, 1)">+</button>
                                        </div>
                                    </td>
                                    <td class="text-end text-primary fw-bold">@((item.Quantity * item.Product.Price).ToString("N0")) đ</td>
                                    <td class="text-center">
                                        <button class="btn btn-link text-danger" onclick="removeItem(@item.ProductId)"><i class="fas fa-trash-alt"></i></button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-end align-items-center mt-4 p-4 bg-light rounded">
                    <div class="me-5 text-end">
                        <p class="mb-0 text-muted small">TỔNG CỘNG:</p>
                        <h2 class="text-danger fw-bold mb-0">@Model.Sum(x => x.Quantity * x.Product.Price).ToString("N0") đ</h2>
                    </div>
                    <button onclick="confirmCheckout()" class="btn btn-success btn-lg px-5 shadow">XÁC NHẬN ĐẶT MÓN</button>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <p class="h4 text-muted">Giỏ hàng trống!</p>
                    <a href="@Url.Action("Index", "Menu")" class="btn btn-primary mt-3">Quay lại Menu</a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function updateQuantity(pId, change) {
            $.post('/Customer/Cart/UpdateQuantity', { productId: pId, change: change }, () => location.reload());
        }

        function removeItem(pId) {
            if(confirm("Xóa món này?")) $.post('/Customer/Cart/RemoveItem', { productId: pId }, () => location.reload());
        }

        function confirmCheckout() {
            Swal.fire({
                title: 'Xác nhận đơn hàng?',
                text: "Món ăn sẽ được chuyển xuống bếp!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Đặt món ngay'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Customer/Cart/Checkout', function (res) {
                        if (res.success) {
                            Swal.fire('Thành công', 'Đang chuyển đơn hàng đến bếp!', 'success')
                            .then(() => window.location.href = '/Customer/Order/OrderDetails/' + res.orderId);
                        } else {
                            Swal.fire('Lỗi', res.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}