@model IEnumerable<DoAnCoSo.Models.Product>

@{
    ViewData["Title"] = "Thực đơn Manwah";
    var categories = ViewBag.Categories as IEnumerable<DoAnCoSo.Models.Category>;
    int? currentCatId = ViewBag.CurrentCategory as int?;
    bool hasTable = ViewBag.HasTable ?? false;
}

@section Styles {
    <style>
        /* Sidebar layout */
        .menu-sidebar {
            position: sticky;
            top: 20px;
            height: fit-content;
            z-index: 100;
            border-radius: 15px;
            overflow: hidden;
            background: #fff;
        }

        .category-link {
            display: block;
            padding: 12px 15px;
            color: #444;
            text-decoration: none !important;
            border-left: 4px solid transparent;
            transition: all 0.3s ease;
            font-weight: 500;
            cursor: pointer;
        }

            .category-link:hover, .category-link.active {
                background: #fff5f5;
                color: #8b0000 !important;
                border-left-color: #8b0000;
            }

            /* Hiệu ứng xoay mũi tên */
            .category-link i.bi-chevron-down {
                transition: transform 0.3s;
            }

            .category-link[aria-expanded="true"] i.bi-chevron-down {
                transform: rotate(180deg);
            }

        /* Card món ăn */
        .product-card {
            border: none;
            border-radius: 15px;
            transition: 0.3s;
            background: #fff;
            cursor: pointer; /* Hiệu ứng bàn tay khi di chuột vào card */
        }

            .product-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
            }

        .product-img-wrapper {
            height: 180px;
            overflow: hidden;
            border-radius: 15px 15px 0 0;
        }

        .product-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s;
        }

        .product-card:hover .product-img {
            transform: scale(1.1);
        }

        .btn-add-cart {
            background-color: #8b0000;
            color: white;
            border-radius: 20px;
            border: none;
            padding: 5px 15px;
        }
    </style>
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-3">
            <div class="menu-sidebar shadow-sm" id="menuAccordion">
                <div class="p-3 border-bottom">
                    <h5 class="fw-bold text-danger m-0 text-uppercase">Danh mục</h5>
                </div>

                <a asp-action="Index" asp-route-categoryId=""
                   class="category-link border-bottom @(currentCatId == null ? "active" : "")">
                    <i class="bi bi-grid-fill me-2"></i> TẤT CẢ MÓN ĂN
                </a>

                @if (categories != null)
                {
                    @foreach (var cat in categories)
                    {
                        var hasSub = cat.SubCategories != null && cat.SubCategories.Any();
                        var isParentActive = currentCatId == cat.CategoryId || (hasSub && cat.SubCategories.Any(s => s.CategoryId == currentCatId));

                        <div class="category-item">
                            <div class="d-flex align-items-center border-bottom">
                                <a asp-action="Index" asp-route-categoryId="@cat.CategoryId"
                                   class="category-link flex-grow-1 @(currentCatId == cat.CategoryId ? "active" : "")">
                                    @cat.CategoryName.ToUpper()
                                </a>
                                @if (hasSub)
                                {
                                    <span class="px-3" data-bs-toggle="collapse" data-bs-target="#collapse-@cat.CategoryId" style="cursor:pointer">
                                        <i class="bi bi-chevron-down"></i>
                                    </span>
                                }
                            </div>

                            @if (hasSub)
                            {
                                <div id="collapse-@cat.CategoryId"
                                     class="collapse @(isParentActive ? "show" : "")"
                                     data-bs-parent="#menuAccordion">
                                    <div class="bg-light">
                                        @foreach (var sub in cat.SubCategories)
                                        {
                                            <a asp-action="Index" asp-route-categoryId="@sub.CategoryId"
                                               class="category-link ps-4 small @(currentCatId == sub.CategoryId ? "active" : "")">
                                                <i class="bi bi-arrow-return-right me-2 text-muted"></i>@sub.CategoryName
                                            </a>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>

        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-end mb-3">
                <h2 class="fw-bold m-0">THỰC ĐƠN TRỨ DANH</h2>
            </div>

            <div class="row g-4">
                @foreach (var item in Model)
                {
                    <div class="col-md-4 col-sm-6">
                        <div class="card h-100 product-card shadow-sm" onclick="showProductDetail(@item.ProductId)">
                            <div class="product-img-wrapper">
                                <img src="~/images/@item.ImagePath"
                                     class="product-img"
                                     alt="@item.ProductName"
                                     onerror="this.src='/images/no-image.png'">
                            </div>
                            <div class="card-body p-3 d-flex flex-column">
                                <small class="text-danger fw-bold">@(item.Category?.CategoryName)</small>
                                <h6 class="fw-bold text-dark mt-1">@item.ProductName</h6>
                                <p class="text-muted small flex-grow-1">@item.Description</p>

                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <span class="text-danger fw-bold fs-5">@item.Price.ToString("N0")đ</span>

                                    @if (hasTable)
                                    {
                                        <button class="btn btn-add-cart btn-add-to-cart"
                                                data-product-id="@item.ProductId"
                                                onclick="event.stopPropagation(); addToCart(@item.ProductId, 1)">
                                            <i class="bi bi-plus-lg"></i> Thêm
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="productModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border-radius: 20px; border: none; overflow: hidden;">
            <div id="productModalContent">
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Hàm hiển thị Modal chi tiết
        function showProductDetail(productId) {
            $.get('/Customer/Menu/GetProductDetail/' + productId, function (data) {
                $('#productModalContent').html(data);
                $('#productModal').modal('show');
            });
        }

        // Hàm thêm vào giỏ hàng
        function addToCart(productId, quantity) {
            // Nếu gọi từ Modal, quantity sẽ được lấy từ input id="quantity"
            var qty = quantity || $('#quantity').val() || 1;

            $.post('/Customer/Cart/AddToCart', { productId: productId, quantity: qty }, function (response) {
                if (response.success) {
                    alert("Đã thêm món vào giỏ!");
                    $('#productModal').modal('hide');
                } else {
                    alert(response.message);
                }
            });
        }
    </script>
}