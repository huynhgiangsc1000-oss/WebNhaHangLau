@model IEnumerable<DoAnCoSo.Models.Product>

@{
    ViewData["Title"] = "Thực đơn Manwah";
    var categories = ViewBag.Categories as IEnumerable<DoAnCoSo.Models.Category>;
    int? currentCatId = ViewBag.CurrentCategory as int?;
}

@section Styles {
    <style>
        .menu-sidebar {
            position: sticky;
            top: 20px;
            height: fit-content;
            z-index: 100;
        }

        .category-link {
            display: block;
            padding: 12px 15px;
            color: #444;
            text-decoration: none !important;
            border-left: 4px solid transparent;
            transition: all 0.3s ease;
            font-weight: 500;
        }

            .category-link:hover, .category-link.active {
                background: #fff5f5;
                color: #8b0000 !important;
                border-left-color: #8b0000;
            }

        .product-card {
            border: none;
            border-radius: 15px;
            transition: 0.3s;
            overflow: hidden;
            background: #fff;
        }

            .product-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
            }

        .product-img-wrapper {
            height: 180px;
            overflow: hidden;
        }

        .product-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .btn-add-cart {
            background-color: #8b0000;
            color: white;
            border-radius: 20px;
            font-size: 0.85rem;
            border: none;
            padding: 5px 15px;
        }

            .btn-add-cart:hover {
                background-color: #a00000;
                color: white;
            }

        .section-title {
            position: relative;
            padding-bottom: 10px;
            margin-bottom: 30px;
        }

            .section-title::after {
                content: '';
                position: absolute;
                left: 0;
                bottom: 0;
                width: 50px;
                height: 3px;
                background: #8b0000;
            }
    </style>
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-3">
            <div class="menu-sidebar shadow-sm rounded bg-white p-2">
                <div class="p-3">
                    <h5 class="fw-bold text-danger m-0 text-uppercase" style="letter-spacing: 1px;">Danh mục</h5>
                </div>

                <a asp-area="Customer" asp-controller="Menu" asp-action="Index" asp-route-categoryId=""
                   class="category-link @(currentCatId == null ? "active" : "")">
                    TẤT CẢ MÓN ĂN
                </a>

                @if (categories != null)
                {
                    @foreach (var cat in categories)
                    {
                        <a asp-area="Customer" asp-controller="Menu" asp-action="Index" asp-route-categoryId="@cat.CategoryId"
                           class="category-link @(currentCatId == cat.CategoryId ? "active" : "")">
                            @cat.CategoryName.ToUpper()
                        </a>

                        @if (cat.SubCategories != null && cat.SubCategories.Any())
                        {
                            @foreach (var sub in cat.SubCategories)
                            {
                                <a asp-area="Customer" asp-controller="Menu" asp-action="Index" asp-route-categoryId="@sub.CategoryId"
                                   class="category-link ps-4 small @(currentCatId == sub.CategoryId ? "active" : "")">
                                    <i class="bi bi-arrow-return-right me-2 text-muted"></i>@sub.CategoryName
                                </a>
                            }
                        }
                    }
                }
            </div>
        </div>

        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-end mb-2">
                <div>
                    <h2 class="fw-bold m-0 text-dark">THỰC ĐƠN TRỨ DANH</h2>
                    <p class="text-muted mb-0">Khám phá tinh hoa ẩm thực Đài Loan</p>
                </div>
                <span class="badge bg-light text-dark border">@Model.Count() món ăn</span>
            </div>
            <hr class="mb-4">

            <div class="row g-4">
                @foreach (var item in Model)
                {
                    <div class="col-md-4 col-sm-6">
                        <div class="card h-100 product-card shadow-sm">
                            <div class="product-img-wrapper">
                                <img src="@(string.IsNullOrEmpty(item.ImagePath) ? "/images/no-image.png" : item.ImagePath)"
                                     class="product-img" alt="@item.ProductName">
                            </div>
                            <div class="card-body p-3 d-flex flex-column">
                                <div class="mb-2">
                                    <small class="text-danger fw-bold text-uppercase" style="font-size: 0.7rem;">
                                        @(item.Category?.CategoryName ?? "Món ăn")
                                    </small>
                                    <h6 class="card-title fw-bold text-dark mt-1 mb-0 text-truncate">@item.ProductName</h6>
                                </div>

                                <p class="text-muted small flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                    @item.Description
                                </p>

                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span class="text-danger fw-bold fs-5">@item.Price.ToString("N0")<small>đ</small></span>
                                    <button class="btn btn-add-cart shadow-sm">
                                        <i class="bi bi-plus-circle me-1"></i> Thêm
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (!Model.Any())
                {
                    <div class="col-12 text-center py-5">
                        <div class="py-5">
                            <i class="bi bi-egg-fried text-muted" style="font-size: 5rem; opacity: 0.3;"></i>
                            <h5 class="mt-3 text-muted">Hiện chưa có món ăn nào trong mục này.</h5>
                            <a asp-action="Index" asp-route-categoryId="" class="btn btn-outline-danger mt-2">Xem tất cả món</a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>