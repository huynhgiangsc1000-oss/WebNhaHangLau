@model DoAnCoSo.Models.Product

<div class="modal-header border-0 pb-0 position-absolute end-0 top-0" style="z-index: 1;">
    <button type="button" class="btn-close bg-white rounded-circle p-2 shadow-sm" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body p-0 overflow-hidden">
    <div class="row g-0">
        <div class="col-md-6">
            <img src="~/images/@Model.ImagePath" class="img-fluid h-100" style="object-fit: cover; min-height: 350px; width: 100%;">
        </div>
        <div class="col-md-6 p-4 d-flex flex-column justify-content-between">
            <div>
                <h3 class="fw-bold text-dark mt-2">@Model.ProductName</h3>
                <p class="text-muted mb-4">@Model.Description</p>
                <div class="d-flex align-items-center mb-4">
                    <span class="text-muted me-2">Giá:</span>
                    <h4 class="text-danger fw-bold mb-0">@Model.Price.ToString("N0") VNĐ</h4>
                </div>
            </div>

            <div class="mt-auto">
                <div class="d-flex align-items-center justify-content-between bg-light p-3 rounded-4 shadow-sm">
                    <div class="d-flex align-items-center border rounded-pill bg-white px-2">
                        <button class="btn btn-link text-dark p-1" onclick="updateQty(-1)">
                            <i class="bi bi-dash-circle fs-4"></i>
                        </button>
                        <input type="number" id="quantity" value="1" class="form-control text-center border-0 fw-bold fs-5 bg-transparent" style="width: 50px;" readonly>
                        <button class="btn btn-link text-dark p-1" onclick="updateQty(1)">
                            <i class="bi bi-plus-circle fs-4"></i>
                        </button>
                    </div>

                    @* Gọi hàm addToCart được định nghĩa ở trang Index *@
                    <button type="button" class="btn btn-success px-4 py-2 rounded-3 fw-bold shadow-sm" onclick="addToCart(@Model.ProductId)">
                        <i class="bi bi-cart-plus me-2"></i> Add to Cart
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function updateQty(val) {
        let input = document.getElementById('quantity');
        let current = parseInt(input.value);
        if(current + val >= 1) input.value = current + val;
    }
</script>