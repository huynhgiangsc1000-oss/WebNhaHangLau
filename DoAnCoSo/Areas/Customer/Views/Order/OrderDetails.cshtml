@model DoAnCoSo.Models.Order
@{
    ViewData["Title"] = "Chi tiết hóa đơn";
    Layout = "_Layout";

    // Lấy phần trăm giảm giá từ Rank và Voucher
    decimal rankPercent = Model.User?.Rank?.DiscountPercent ?? 0;
    decimal promoPercent = Model.Promotion?.DiscountValue ?? 0;

    // CHỈ LẤY GIÁ TRỊ CAO NHẤT (Không cộng dồn)
    decimal appliedPercent = Math.Max(rankPercent, promoPercent);

    decimal discountAmount = Model.TotalAmount * (appliedPercent / 100m);
    decimal finalPrice = Model.TotalAmount - discountAmount;
}

@Html.AntiForgeryToken()

<div class="container mt-4 mb-5">
    @if (Context.Request.Query.ContainsKey("error"))
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-4 mb-4 shadow-sm" role="alert">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Thanh toán thất bại!</strong> Vui lòng kiểm tra lại số dư hoặc thẻ của bạn.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-white border-0 py-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold text-dark mb-1">Chi tiết đơn hàng</h2>
                    <p class="text-muted mb-0">Bàn: <span class="badge bg-danger">@(Model.Table?.TableName ?? "N/A")</span> | Mã: #@Model.OrderId</p>
                </div>
                <div class="text-end">
                    <span class="badge @(Model.Status == "Completed" ? "bg-success" : "bg-warning") p-2 px-4 rounded-pill">@Model.Status</span>
                    <div class="small text-muted mt-1">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
            </div>
        </div>

        <div class="card-body p-4 pt-0">
            <div class="row g-4">
                <!-- Danh sách món ăn -->
                <div class="col-lg-8">
                    <div class="table-responsive border rounded-4 bg-white">
                        <table class="table align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 border-0">Món ăn</th>
                                    <th class="text-center border-0">Số lượng</th>
                                    <th class="text-end pe-4 border-0">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderDetails)
                                {
                                    <tr>
                                        <td class="ps-4 py-3">
                                            <div class="d-flex align-items-center">
                                                <img src="~/images/@(item.Product?.ImagePath ?? "no-image.png")" class="rounded-3 me-3 shadow-sm" style="width:60px; height:60px; object-fit:cover;" />
                                                <div>
                                                    <span class="fw-bold d-block text-dark">@item.Product.ProductName</span>
                                                    <small class="text-muted">@item.UnitPrice.ToString("N0") đ</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center fw-bold text-primary">x @item.Quantity</td>
                                        <td class="text-end pe-4 fw-bold">@((item.Quantity * item.UnitPrice).ToString("N0")) đ</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Chi tiết thanh toán -->
                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm rounded-4 bg-light p-2">
                        <div class="card-body">
                            <h5 class="fw-bold mb-4">Chi tiết thanh toán</h5>

                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Tạm tính:</span>
                                <span class="fw-bold">@Model.TotalAmount.ToString("N0") đ</span>
                            </div>

                            @if (appliedPercent > 0)
                            {
                                <div class="d-flex justify-content-between mb-1 text-success fw-bold">
                                    <span>
                                        <i class="fas fa-percentage me-1"></i>
                                        Ưu đãi áp dụng:
                                    </span>
                                    <span>- @appliedPercent%</span>
                                </div>
                                <div class="small text-muted mb-3 italic">
                                    (@(appliedPercent == rankPercent ? "Áp dụng theo hạng " + Model.User?.Rank?.RankName : "Áp dụng theo mã ưu đãi"))
                                </div>
                            }

                            <!-- Ô nhập mã giảm giá -->
                            @if (Model.Status != "Completed" && Model.Status != "Paid")
                            {
                                <div class="mt-3 mb-3 p-3 bg-white rounded-3 border border-dashed">
                                    <label class="small fw-bold text-muted mb-2">Sử dụng mã giảm giá</label>
                                    <div class="input-group">
                                        <input type="text" id="couponInput" class="form-control form-control-sm" placeholder="Nhập mã..." value="@Model.Promotion?.CouponCode">
                                        <button class="btn btn-dark btn-sm px-3" type="button" onclick="applyCoupon(@Model.OrderId)">Áp dụng</button>
                                    </div>
                                    <div id="promoMsg" class="small mt-1"></div>
                                </div>
                            }

                            <hr class="my-4">

                            <div class="d-flex justify-content-between mb-4 align-items-center">
                                <span class="h5 fw-bold mb-0">Tổng cộng:</span>
                                <span class="h3 text-danger fw-bold mb-0">@finalPrice.ToString("N0") đ</span>
                            </div>

                            @if (Model.Status != "Completed")
                            {
                                <div class="mb-4">
                                    <label class="small fw-bold text-muted mb-2">Phương thức thanh toán</label>
                                    <select class="form-select form-select-lg border-2 rounded-3 fs-6" id="paymentMethod">
                                        <option value="Tiền mặt">💵 Tiền mặt tại quầy</option>
                                        <option value="VNPAY">💳 Ví điện tử VNPAY</option>
                                    </select>
                                </div>
                                <div class="d-grid gap-3">
                                    <button type="button" onclick="confirmPayment(@Model.OrderId)" class="btn btn-danger fw-bold py-3 rounded-pill shadow">XÁC NHẬN THANH TOÁN</button>
                                    <a href="@Url.Action("Index", "Menu")" class="btn btn-outline-dark rounded-pill fw-bold py-2">ĐẶT THÊM MÓN</a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Hàm áp dụng Voucher
        function applyCoupon(orderId) {
            const code = $('#couponInput').val();
            if (!code) return;

            $.post('@Url.Action("ApplyPromotion", "Order", new { area = "Customer" })',
                { orderId: orderId, couponCode: code },
                function (res) {
                    if (res.success) {
                        Swal.fire({
                            title: 'Thành công!',
                            text: res.message,
                            icon: 'success',
                            timer: 1500,
                            showConfirmButton: false
                        }).then(() => location.reload());
                    } else {
                        $('#promoMsg').text(res.message).addClass('text-danger');
                    }
                }
            );
        }

        function confirmPayment(orderId) {
             const method = $('#paymentMethod').val();
             const token = $('input[name="__RequestVerificationToken"]').val();

             // Nếu chọn VNPAY thì đi tới trang thanh toán online
             if (method === "VNPAY") {
                 window.location.href = '@Url.Action("PayVnpay", "Order", new { area = "Customer" })' + '?orderId=' + orderId;
                 return;
             }

             // Nếu chọn Tiền mặt
             Swal.fire({
                 title: 'Xác nhận thanh toán?',
                 text: "Yêu cầu thanh toán tiền mặt sẽ được gửi đến quầy. Bàn của bạn sẽ được giữ cho đến khi hoàn tất tại quầy.",
                 icon: 'info',
                 showCancelButton: true,
                 confirmButtonColor: '#dc3545',
                 confirmButtonText: 'Đồng ý',
                 cancelButtonText: 'Hủy'
             }).then((result) => {
                 if (result.isConfirmed) {
                     // Gọi hàm RequestCashPayment để báo cho Admin
                     $.post('@Url.Action("RequestCashPayment", "Order", new { area = "Customer" })',
                     {
                         orderId: orderId,
                         __RequestVerificationToken: token
                     },
                     function (res) {
                         if (res.success) {
                             Swal.fire({
                                 title: 'Thành công!',
                                 text: res.message,
                                 icon: 'success'
                             }).then(() => {
                                 // Sau khi khách nhấn OK, đẩy họ về trang lịch sử đơn hàng
                                 window.location.href = '@Url.Action("History", "Order")';
                             });
                         } else {
                             Swal.fire('Lỗi', res.message, 'error');
                         }
                     });
                 }
             });
         }
    </script>
    <style>
        .border-dashed {
            border-style: dashed !important;
        }

        .italic {
            font-style: italic;
        }
    </style>
}