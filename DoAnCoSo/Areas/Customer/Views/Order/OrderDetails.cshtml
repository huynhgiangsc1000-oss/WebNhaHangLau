@model DoAnCoSo.Models.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
    Layout = "_Layout";
}

<div class="container mt-4 mb-5">
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        @* Header trang chi tiết *@
        <div class="card-header bg-white border-0 py-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold text-dark mb-1">Chi tiết đơn hàng</h2>
                    <p class="text-muted mb-0">
                        Phục vụ tại: <span class="badge bg-danger rounded-pill px-3">@(Model.Table?.TableName ?? "N/A")</span>
                        | Mã đơn: #@Model.OrderId
                    </p>
                </div>
                <div class="text-end">
                    @{
                        var statusClass = Model.Status switch
                        {
                            "Pending" => "bg-warning text-dark",
                            "Confirmed" => "bg-info text-white",
                            "Processing" => "bg-primary text-white",
                            "Completed" => "bg-success text-white",
                            _ => "bg-secondary text-white"
                        };
                        var statusText = Model.Status switch
                        {
                            "Pending" => "Đang chờ xác nhận",
                            "Confirmed" => "Đã xác nhận đơn",
                            "Processing" => "Đang chế biến",
                            "Completed" => "Đã hoàn thành",
                            _ => Model.Status
                        };
                    }
                    <span class="badge @statusClass p-2 px-4 rounded-pill fs-6 shadow-sm">
                        <i class="fas fa-info-circle me-1"></i> @statusText
                    </span>
                </div>
            </div>
        </div>

        <div class="card-body p-4 pt-0">
            <div class="row">
                @* Danh sách món ăn đã đặt *@
                <div class="col-lg-8">
                    <div class="table-responsive rounded-3 border">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4">Món ăn</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end">Đơn giá</th>
                                    <th class="text-end pe-4">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderDetails)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center py-2">
                                                <img src="~/images/@item.Product.ImagePath" class="rounded-3"
                                                     style="width: 50px; height: 50px; object-fit: cover;"
                                                     onerror="this.src='/images/no-image.png'" />
                                                <div class="ms-3">
                                                    <span class="fw-bold d-block text-dark">@item.Product.ProductName</span>
                                                    <small class="text-muted">Mã món: #@item.ProductId</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center fw-bold">x @item.Quantity</td>
                                        <td class="text-end">@item.UnitPrice.ToString("N0") đ</td>
                                        <td class="text-end pe-4 text-danger fw-bold">
                                            @((item.Quantity * item.UnitPrice).ToString("N0")) đ
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-4 p-3 bg-light rounded-3">
                        <p class="small text-muted mb-0">
                            <i class="fas fa-clock me-2"></i>Thời gian đặt món: @Model.OrderDate.ToString("dd/MM/yyyy HH:mm:ss")
                        </p>
                    </div>
                </div>

                @* Cột thanh toán *@
                <div class="col-lg-4 mt-4 mt-lg-0">
                    <div class="card bg-white border shadow-sm rounded-4">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4 border-bottom pb-2">Tóm tắt thanh toán</h5>

                            <div class="d-flex justify-content-between mb-3 text-muted">
                                <span>Tổng tiền món:</span>
                                <span class="fw-bold text-dark">@Model.TotalAmount.ToString("N0") đ</span>
                            </div>

                            @* Ưu đãi Rank *@
                            <div class="py-3 border-top border-bottom my-3">
                                <label class="small fw-bold text-uppercase text-muted d-block mb-2">Ưu đãi thành viên</label>
                                @if (Model.User?.Rank != null)
                                {
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="text-success fw-medium">
                                            <i class="fas fa-award me-1"></i> @Model.User.Rank.RankName
                                        </span>
                                        <span class="badge bg-success">- @Model.User.Rank.DiscountPercent%</span>
                                    </div>
                                }
                                else
                                {
                                    <p class="small text-muted mb-0">Khách hàng phổ thông</p>
                                }
                            </div>

                            @* Tổng cuối *@
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <span class="h5 mb-0 fw-bold">Thành tiền:</span>
                                <div class="text-end">
                                    @{
                                        decimal discountPercent = Model.User?.Rank?.DiscountPercent ?? 0;
                                        decimal finalPrice = Model.TotalAmount * (1 - (discountPercent / 100));
                                    }
                                    <span class="h3 text-danger fw-bold d-block mb-0">@finalPrice.ToString("N0") đ</span>
                                    <small class="text-muted">(Đã bao gồm VAT)</small>
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="small fw-bold mb-2">Phương thức thanh toán:</label>
                                <div class="p-3 border rounded-3 bg-light">
                                    <i class="fas fa-money-bill-wave text-success me-2"></i> Tiền mặt tại quầy
                                </div>
                            </div>

                            <div class="d-grid gap-2">
                                <button onclick="window.print()" class="btn btn-dark btn-lg rounded-pill fw-bold py-3 shadow-sm">
                                    <i class="fas fa-print me-2"></i>IN HÓA ĐƠN
                                </button>
                                <a href="@Url.Action("History", "Order")" class="btn btn-outline-secondary rounded-pill py-2">
                                    Quay lại lịch sử
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card-header {
        border-bottom: 1px solid #f8f9fa !important;
    }

    .table thead th {
        border-top: none;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .rounded-4 {
        border-radius: 1rem !important;
    }

    @@media print {
        .btn, .badge, .card-header div:last-child {
            display: none !important;
        }

        .container {
            width: 100%;
            max-width: none;
            margin: 0;
            padding: 0;
        }

        .card {
            border: none !important;
            box-shadow: none !important;
        }
    }
</style>