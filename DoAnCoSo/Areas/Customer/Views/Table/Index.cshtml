@model IEnumerable<DoAnCoSo.Models.Table>
@{
    ViewData["Title"] = "Sơ đồ nhà hàng";
}

<div class="container py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3">
            <h5 class="mb-1 fw-bold text-uppercase text-primary">
                <i class="bi bi-grid-3x3-gap-fill me-2"></i>Sơ đồ nhà hàng
            </h5>
            <p class="text-muted small mb-0">
                Chọn bàn để xem mã QR (Bàn <span class="text-success fw-bold">Xanh</span> là bàn trống, <span class="text-danger fw-bold">Đỏ</span> là đang có khách)
            </p>
        </div>
        <div class="card-body p-4">
            <div class="table-grid">
                @foreach (var table in Model)
                {
                    bool isOccupied = table.Status == "Occupied";
                    string statusText = isOccupied ? "Đang sử dụng" : "Còn trống";
                    string colorClass = isOccupied ? "table-occupied" : "table-empty";

                    <div class="table-item @colorClass" data-bs-toggle="modal" data-bs-target="#qrModal-@table.TableId">
                        <div class="table-icon">
                            <i class="bi bi-tablet-landscape"></i>
                        </div>
                        <div class="table-name">@table.TableName</div>
                        <div class="table-status">@statusText</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@foreach (var table in Model)
{
    bool isOccupied = table.Status == "Occupied";

    <div class="modal fade" id="qrModal-@table.TableId" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title w-100 text-center fw-bold">Thông tin @table.TableName</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center p-4">
                    @if (isOccupied)
                    {
                        <div class="py-3">
                            <i class="bi bi-person-fill-lock display-4 text-danger"></i>
                            <p class="mt-3 fw-bold text-danger">Bàn này hiện đang có khách!</p>
                            <p class="text-muted small">Vui lòng chọn bàn khác hoặc liên hệ nhân viên nếu bạn muốn ghép bàn.</p>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(table.QrCode))
                    {
                        <img src="@table.QrCode" class="img-fluid mb-3 p-2 border rounded" style="max-width: 250px;" />
                        <p class="text-muted small">Quét mã để bắt đầu đặt món cho <strong>@table.TableName</strong></p>

                        <div class="mt-3">
                            @* LINK QUAN TRỌNG: Phải dẫn về AccessTable để kiểm tra Login *@
                            <a href="@Url.Action("AccessTable", "Table", new { area = "Customer", id = table.TableId })"
                               class="btn btn-primary btn-sm rounded-pill px-4">
                                <i class="bi bi-qr-code-scan me-2"></i>Giả lập quét mã này
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="py-4 text-secondary">
                            <i class="bi bi-qr-code-scan display-1"></i>
                            <p class="mt-2">Chưa cập nhật mã QR cho bàn này</p>
                        </div>
                    }
                </div>
                <div class="modal-footer border-0 justify-content-center pb-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
                </div>
            </div>
        </div>
    </div>
}

@section Styles {
    <style>
        .table-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
            gap: 20px;
        }

        .table-item {
            border: 2px solid;
            border-radius: 12px;
            padding: 25px 15px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            background-color: #fff;
        }

            .table-item:hover {
                transform: translateY(-5px);
                box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            }

        .table-icon {
            font-size: 30px;
            margin-bottom: 10px;
        }

        .table-name {
            font-weight: bold;
            font-size: 16px;
            margin-bottom: 5px;
        }

        .table-status {
            font-size: 13px;
            font-weight: 500;
        }

        .table-empty {
            border-color: #28a745 !important;
            color: #28a745 !important;
            background-color: #f8fff9;
        }

        .table-occupied {
            border-color: #dc3545 !important;
            color: #dc3545 !important;
            background-color: #fff8f8;
            opacity: 0.8;
        }

        .modal-content {
            border-radius: 20px;
        }
    </style>
}