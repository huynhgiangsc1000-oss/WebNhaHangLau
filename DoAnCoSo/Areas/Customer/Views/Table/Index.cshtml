@model IEnumerable<DoAnCoSo.Models.Table>
@{
    ViewData["Title"] = "Sơ đồ nhà hàng";
}

<div class="container py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 text-center">
            <h5 class="mb-1 fw-bold text-uppercase text-primary">
                <i class="bi bi-grid-3x3-gap-fill me-2"></i>Sơ đồ nhà hàng
            </h5>
            <p class="text-muted small mb-0">Chọn bàn để bắt đầu trải nghiệm dịch vụ</p>
        </div>

        <div class="d-flex justify-content-center flex-wrap gap-3 py-2 border-bottom">
            <div class="small d-flex align-items-center"><span class="badge bg-success me-1" style="width:12px;height:12px;">&nbsp;</span> Còn trống</div>
            <div class="small d-flex align-items-center"><span class="badge bg-warning me-1" style="width:12px;height:12px;">&nbsp;</span> Đã đặt trước</div>
            <div class="small d-flex align-items-center"><span class="badge bg-danger me-1" style="width:12px;height:12px;">&nbsp;</span> Đang có khách</div>
        </div>

        <div class="card-body p-4">
            <div class="table-grid">
                @foreach (var table in Model)
                {
                    // Logic kiểm tra trạng thái
                    var allBookingsToday = table.Bookings?.Where(b => (b.Status == "Confirmed" || b.Status == "Pending") && b.BookingDate.Date == DateTime.Today).OrderBy(b => b.BookingDate).ToList();
                    var upcomingBooking = allBookingsToday?.FirstOrDefault(b => b.BookingDate >= DateTime.Now.AddHours(-1) && b.BookingDate <= DateTime.Now.AddHours(1));
                    var anyBookingToday = allBookingsToday?.FirstOrDefault(b => b.BookingDate > DateTime.Now);

                    bool isOccupied = (table.Status == "Occupied" || table.Status == "Busy");
                    bool isReservedNow = upcomingBooking != null;
                    bool isReservedLater = upcomingBooking == null && anyBookingToday != null;

                    string statusText = isOccupied ? "Đang sử dụng" : (isReservedNow ? "Đã đặt trước" : "Còn trống");
                    string colorClass = isOccupied ? "table-occupied" : (isReservedNow ? "table-reserved" : "table-empty");

                    <div class="table-item @colorClass" data-bs-toggle="modal" data-bs-target="#qrModal-@table.TableId">
                        <div class="table-icon">
                            <i class="bi bi-tablet-landscape"></i>
                        </div>
                        <div class="table-name">@table.TableName</div>

                        <div class="table-capacity">
                            <i class="bi bi-people-fill me-1"></i>@table.Capacity người
                        </div>

                        <div class="table-status mt-1">@statusText</div>

                        @if (isReservedNow && !isOccupied)
                        {
                            <div class="small fw-bold text-warning animate__animated animate__pulse animate__infinite">
                                <i class="bi bi-clock me-1"></i>@upcomingBooking.BookingDate.ToString("HH:mm")
                            </div>
                        }
                        else if (isReservedLater && !isOccupied)
                        {
                            <div class="small fw-bold text-muted mt-1">
                                <i class="bi bi-calendar-event me-1"></i>Có khách lúc: @anyBookingToday.BookingDate.ToString("HH:mm")
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@foreach (var table in Model)
{
    var allBookingsToday = table.Bookings?.Where(b => (b.Status == "Confirmed" || b.Status == "Pending") && b.BookingDate.Date == DateTime.Today).OrderBy(b => b.BookingDate).ToList();
    var upcomingBooking = allBookingsToday?.FirstOrDefault(b => b.BookingDate >= DateTime.Now.AddHours(-1) && b.BookingDate <= DateTime.Now.AddHours(1));
    var anyBookingToday = allBookingsToday?.FirstOrDefault(b => b.BookingDate > DateTime.Now);

    bool isOccupied = (table.Status == "Occupied" || table.Status == "Busy");
    bool isReservedNow = upcomingBooking != null;
    bool isReservedLater = upcomingBooking == null && anyBookingToday != null;

    <div class="modal fade" id="qrModal-@table.TableId" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header border-0 pb-0 justify-content-center position-relative">
                    <div class="text-center w-100 mt-3">
                        <h5 class="modal-title fw-bold mb-1">Bàn @table.TableName</h5>
                        <span class="badge bg-light text-dark border fw-normal">
                            <i class="bi bi-people-fill me-1 text-primary"></i> Sức chứa tối đa: @table.Capacity người
                        </span>
                    </div>
                    <button type="button" class="btn-close position-absolute" style="right: 15px; top: 15px;" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body text-center p-4">
                    @if (isOccupied)
                    {
                        <div class="py-3">
                            <i class="bi bi-person-fill-lock display-4 text-danger"></i>
                            <p class="mt-3 fw-bold text-danger">Bàn này hiện đang có khách!</p>
                            <p class="text-muted small">
                                Nếu bạn là khách vãng lai đã được nhân viên check-in gán vào bàn này,
                                vui lòng ấn nút bên dưới để tiến hành Đăng nhập/Đăng ký tài khoản và gọi món.
                            </p>

                            <div class="d-grid gap-2 mt-3">
                                <a href="@Url.Action("AccessTable", "Table", new { area = "Customer", id = table.TableId })"
                                   class="btn btn-danger btn-lg rounded-pill px-4 shadow-sm">
                                    <i class="bi bi-box-arrow-in-right me-2"></i>Tôi ngồi bàn này & Gọi món
                                </a>
                            </div>
                        </div>
                    }
                    else if (isReservedNow)
                    {
                        <div class="py-3">
                            <i class="bi bi-calendar-check-fill display-4 text-warning"></i>
                            <p class="mt-3 fw-bold text-warning">Bàn đã được đặt vào lúc @upcomingBooking.BookingDate.ToString("HH:mm")!</p>
                            <p class="text-muted small">Bàn này đã có khách hẹn trước và sắp tới giờ. Nếu bạn là chủ đơn đặt này, vui lòng nhấn nút dưới.</p>
                            <a href="@Url.Action("AccessTable", "Table", new { area = "Customer", id = table.TableId })"
                               class="btn btn-warning btn-sm rounded-pill px-4 mt-2 shadow-sm">
                                <i class="bi bi-check-circle me-2"></i>Tôi là khách đặt bàn này
                            </a>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(table.QrCode))
                    {
                        <div class="qr-container p-3 bg-white d-inline-block border rounded mb-3">
                            <img src="@table.QrCode" class="img-fluid" style="max-width: 220px;" />
                        </div>
                        
                        @if (isReservedLater)
                        {
                            <div class="alert alert-warning py-2 mb-3 small text-start">
                                <i class="bi bi-info-circle-fill me-1"></i> Bàn này có khách đặt trước vào lúc <strong>@anyBookingToday.BookingDate.ToString("HH:mm")</strong>. 
                                Quý khách vui lòng kết thúc bữa ăn trước khoảng thời gian này nhé!
                            </div>
                        }

                        <p class="text-muted small mb-3">Quét mã hoặc nhấn nút bên dưới để xem thực đơn tại <strong>@table.TableName</strong></p>

                        <div class="d-grid gap-2">
                            <a href="@Url.Action("AccessTable", "Table", new { area = "Customer", id = table.TableId })"
                               class="btn btn-primary btn-lg rounded-pill px-4 shadow">
                                <i class="bi bi-qr-code-scan me-2"></i>Vào bàn & Gọi món
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@section Styles {
    <style>
        .table-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
            gap: 15px;
        }

        .table-item {
            border: 2px solid;
            border-radius: 15px;
            padding: 15px 10px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            background-color: #fff;
            display: flex;
            flex-direction: column;
            justify-content: center;
            min-height: 150px;
        }

            .table-item:hover {
                transform: translateY(-5px);
                box-shadow: 0 8px 15px rgba(0,0,0,0.1);
            }

        .table-icon {
            font-size: 24px;
            margin-bottom: 5px;
        }

        .table-name {
            font-weight: 800;
            font-size: 16px;
            text-transform: uppercase;
        }

        .table-capacity {
            font-size: 13px;
            font-weight: 500;
            opacity: 0.9;
        }

        .table-status {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* MÀU XANH: Bàn trống */
        .table-empty {
            border-color: #28a745 !important;
            color: #28a745 !important;
            background-color: #f8fff9;
        }

        /* MÀU VÀNG: Đã đặt trước */
        .table-reserved {
            border-color: #ffc107 !important;
            color: #856404 !important;
            background-color: #fffdf5;
        }

        /* MÀU ĐỎ: Đang sử dụng */
        .table-occupied {
            border-color: #dc3545 !important;
            color: #dc3545 !important;
            background-color: #fff8f8;
        }

        .modal-content {
            border-radius: 20px;
        }

        .qr-container {
            transition: transform 0.3s ease;
        }

            .qr-container:hover {
                transform: scale(1.05);
            }
    </style>
}