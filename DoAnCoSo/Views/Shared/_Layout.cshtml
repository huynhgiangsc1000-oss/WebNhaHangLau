@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 江安火锅 Manwah</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <style>
        /* --- ADMIN LAYOUT STYLES --- */
        .admin-wrapper {
            display: flex;
            min-height: 100vh;
        }

        .admin-sidebar {
            width: 260px;
            background: #1a1a1a;
            color: white;
            position: fixed;
            height: 100vh;
            overflow-y: auto;
            z-index: 1000;
            border-right: 1px solid #333;
        }

        .admin-main-content {
            flex: 1;
            margin-left: 260px;
            background-color: #f4f6f9;
            display: flex;
            flex-direction: column;
        }

        .admin-header {
            background: white;
            padding: 12px 30px;
            border-bottom: 1px solid #dee2e6;
            position: sticky;
            top: 0;
            z-index: 999;
        }

        .nav-category {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1.2px;
            color: #6c757d;
            padding: 20px 15px 8px;
            font-weight: 700;
        }

        .custom-sidebar-nav .nav-link {
            color: #adb5bd;
            padding: 12px 20px;
            margin: 2px 10px;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            text-decoration: none;
            border-radius: 8px;
        }

            .custom-sidebar-nav .nav-link i {
                margin-right: 12px;
                font-size: 1.1rem;
            }

            .custom-sidebar-nav .nav-link:hover {
                background: rgba(255,255,255,0.05);
                color: #fff;
            }

            .custom-sidebar-nav .nav-link.active {
                background: #dc3545;
                color: white;
                box-shadow: 0 4px 10px rgba(220, 53, 69, 0.3);
            }

        /* --- CUSTOMER NAV STYLES --- */
        .navbar-mw {
            background: white;
            box-shadow: 0 2px 15px rgba(0,0,0,0.05);
            padding: 10px 0;
        }

        .nav-link-custom {
            color: #333;
            font-weight: 600;
            padding: 10px 18px;
            text-decoration: none;
            transition: 0.3s;
            font-size: 0.95rem;
        }

            .nav-link-custom:hover {
                color: #dc3545;
            }

        .cart-wrapper {
            position: relative;
            font-size: 1.4rem;
            color: #333;
            transition: 0.2s;
        }

            .cart-wrapper:hover {
                color: #dc3545;
            }

        #cart-badge-nav {
            position: absolute;
            top: -5px;
            right: -8px;
            background: #dc3545;
            font-size: 0.65rem;
            padding: 3px 6px;
        }

        .btn-reserve {
            background-color: #dc3545;
            border: none;
            font-weight: 600;
            transition: 0.3s;
        }

            .btn-reserve:hover {
                background-color: #b02a37;
                transform: translateY(-1px);
            }
    </style>
</head>
<body>
    @{
        // Kiểm tra Area hiện tại
        var area = ViewContext.RouteData.Values["area"]?.ToString();
        bool isAdminArea = area == "Admin";

        // Lấy thông tin bàn từ Session (nếu có)
        var tableName = HttpContextAccessor.HttpContext?.Session.GetString("TableName");
    }

    @if (isAdminArea)
    {
        <div class="admin-wrapper">
            <div class="admin-sidebar shadow-lg">
                <div class="sidebar-header text-center py-4 border-bottom border-secondary">
                    <h5 class="brand-name mb-0 text-white fw-bold">MANWAH <span class="text-danger">ADMIN</span></h5>
                </div>

                <nav class="nav flex-column px-2 custom-sidebar-nav mt-3">
                    <div class="nav-category">Hệ thống</div>
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                       asp-area="Admin" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2"></i><span>Bảng điều khiển</span>
                    </a>

                    <div class="nav-category">Nghiệp vụ</div>
                    @* Cả Admin và Staff đều thấy 2 mục này *@
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Order" ? "active" : "")"
                       asp-area="Admin" asp-controller="Order" asp-action="Index">
                        <i class="bi bi-receipt-cutoff"></i><span>Đơn hàng</span>
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Table" ? "active" : "")"
                       asp-area="Admin" asp-controller="Table" asp-action="Index">
                        <i class="bi bi-grid-3x3-gap"></i><span>Quản lý bàn</span>
                    </a>

                    @* Chỉ Admin mới thấy các mục quản lý hệ thống bên dưới *@
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="nav-category">Thực đơn</div>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Product" ? "active" : "")"
                           asp-area="Admin" asp-controller="Product" asp-action="Index">
                            <i class="bi bi-cup-hot"></i><span>Món ăn</span>
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "active" : "")"
                           asp-area="Admin" asp-controller="Category" asp-action="Index">
                            <i class="bi bi-collection"></i><span>Loại món</span>
                        </a>

                        <div class="nav-category">Nhân sự & Khách hàng</div>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")"
                           asp-area="Admin" asp-controller="User" asp-action="Index">
                            <i class="bi bi-people"></i><span>Khách hàng</span>
                        </a>
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Staff" ? "active" : "")"
                           asp-area="Admin" asp-controller="Staff" asp-action="Index">
                            <i class="bi bi-person-badge"></i><span>Nhân viên</span>
                        </a>
                    }
                </nav>
            </div>

            <div class="admin-main-content">
                <header class="admin-header d-flex justify-content-between align-items-center">
                    <div class="page-title">
                        <h5 class="mb-0 fw-bold">Trang Quản Trị</h5>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-0" style="--bs-breadcrumb-divider: '›';">
                                <li class="breadcrumb-item small text-muted">Hệ thống</li>
                                <li class="breadcrumb-item small active fw-semibold text-danger">@ViewContext.RouteData.Values["controller"]</li>
                            </ol>
                        </nav>
                    </div>

                    <div class="user-profile dropdown">
                        <div class="d-flex align-items-center shadow-sm p-1 rounded-pill bg-white px-3 border"
                             data-bs-toggle="dropdown" style="cursor: pointer;">
                            <div class="text-end me-2 d-none d-sm-block">
                                <div class="fw-bold small text-dark">@User.Identity.Name</div>
                                @* Hiển thị chức danh động theo Role *@
                                <div class="text-muted" style="font-size: 0.65rem;">
                                    @(User.IsInRole("Admin") ? "Quản trị viên" : "Nhân viên")
                                </div>
                            </div>
                            <div class="bg-dark rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                <i class="bi bi-person-fill text-white"></i>
                            </div>
                        </div>
                        <ul class="dropdown-menu dropdown-menu-end border-0 shadow mt-2">
                            <li><a class="dropdown-item py-2" href="#"><i class="bi bi-gear me-2"></i>Cài đặt</a></li>
                            <li><a class="dropdown-item py-2" asp-area="Customer" asp-controller="Home" asp-action="Index"><i class="bi bi-eye me-2"></i>Xem Website</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item py-2 text-danger fw-bold" asp-area="Admin" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                </a>
                            </li>
                        </ul>
                    </div>
                </header>

                <div class="p-4">
                    @RenderBody()
                </div>

                <footer class="admin-footer py-3 text-center bg-white border-top mt-auto">
                    <p class="mb-0 text-muted small">&copy; 2026 江安火锅 Manwah - Admin Control Panel</p>
                </footer>
            </div>
        </div>
    }
    else
    {
        <nav class="navbar navbar-expand-lg navbar-mw sticky-top">
            <div class="container">
                <a class="navbar-brand" asp-area="Customer" asp-controller="Home" asp-action="Index">
                    <img src="~/images/Logo.png" alt="Manwah Logo" style="height: 55px;" asp-append-version="true">
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mwNav">
                    <i class="bi bi-list fs-2"></i>
                </button>

                <div class="collapse navbar-collapse" id="mwNav">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item"><a class="nav-link-custom" asp-area="Customer" asp-controller="Menu" asp-action="Index">THỰC ĐƠN</a></li>
                        <li class="nav-item"><a class="nav-link-custom" asp-area="Customer" asp-controller="Table" asp-action="Index">SƠ ĐỒ BÀN</a></li>
                        <li class="nav-item"><a class="nav-link-custom" href="#">KHUYẾN MÃI</a></li>
                        <li class="nav-item"><a class="nav-link-custom" href="#">VỀ CHÚNG TÔI</a></li>
                    </ul>

                    <div class="d-flex align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <a asp-area="Customer" asp-controller="Order" asp-action="History" class="cart-wrapper me-3" title="Lịch sử đơn hàng">
                                <i class="bi bi-clock-history"></i>
                            </a>

                            <div class="me-3 text-end">
                                <span class="fw-bold d-block small">@User.Identity.Name</span>
                                @if (!string.IsNullOrEmpty(tableName))
                                {
                                    <span class="badge bg-danger">BÀN: @tableName</span>
                                }
                            </div>
                            <a class="nav-link-custom small p-0 text-muted" asp-area="Customer" asp-controller="Account" asp-action="Logout">Thoát</a>
                        }
                        else
                        {
                            <a class="nav-link-custom" asp-area="Customer" asp-controller="Account" asp-action="Login">ĐĂNG NHẬP</a>
                        }

                        <a asp-area="Customer" asp-controller="Cart" asp-action="Index" class="cart-wrapper ms-3 me-2">
                            <i class="bi bi-bag-heart"></i>
                            <span id="cart-badge-nav" class="badge rounded-pill shadow-sm" style="display:none;">0</span>
                        </a>

                        <a asp-area="Customer" asp-controller="Table" asp-action="Index" class="btn btn-danger btn-reserve ms-3 rounded-pill px-4">ĐẶT BÀN</a>
                    </div>
                </div>
            </div>
        </nav>

        <main role="main">
            @RenderBody()
        </main>

        <footer class="py-5 bg-dark text-white mt-5">
            <div class="container text-center">
                <img src="~/images/Logo.png" alt="Logo" style="height: 50px; filter: brightness(0) invert(1);" class="mb-3">
                <p class="mb-1 fw-bold">江安火锅 MANWAH TAIWANESE HOTPOT</p>
                <p class="text-secondary small mb-4">Nơi hương vị lẩu Đài Loan truyền thống thăng hoa</p>
                <div class="mb-4">
                    <a href="#" class="text-white mx-2 fs-4"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="text-white mx-2 fs-4"><i class="bi bi-instagram"></i></a>
                    <a href="#" class="text-white mx-2 fs-4"><i class="bi bi-youtube"></i></a>
                </div>
                <hr class="border-secondary opacity-25">
                <p class="mb-0 small text-secondary">&copy; 2026 Manwah Taiwanese Hotpot. All Rights Reserved.</p>
            </div>
        </footer>
    }

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            // Khởi tạo badge giỏ hàng ngay khi tải trang
            updateCartBadge();
        });

        function updateCartBadge() {
            var url = '@Url.Action("GetCartCount", "Cart", new { area = "Customer" })';
            $.ajax({
                url: url,
                type: 'GET',
                cache: false,
                success: function (count) {
                    var badge = $('#cart-badge-nav');
                    if (count > 0) {
                        badge.text(count).show();
                    } else {
                        badge.hide();
                    }
                },
                error: function() {
                    console.warn("Could not update cart badge.");
                }
            });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>