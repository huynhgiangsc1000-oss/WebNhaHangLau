@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 江安火锅 Manwah</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)

    <style>
        :root {
            --mw-red: #dc3545;
            --mw-dark: #1a1a1a;
            --mw-gray: #f8f9fa;
        }

        body {
            font-family: 'Lexend', sans-serif;
        }

        /* --- ADMIN SHARED --- */
        .admin-sidebar {
            width: 280px;
            background: var(--mw-dark);
            min-height: 100vh;
            position: fixed;
            z-index: 1030;
        }

        .admin-main {
            margin-left: 280px;
            background: #f4f7f6;
            min-height: 100vh;
        }

        .nav-link-admin {
            color: #adb5bd;
            padding: 0.8rem 1.2rem;
            margin: 0.2rem 1rem;
            border-radius: 10px;
            display: flex;
            align-items: center;
            transition: all 0.3s;
            text-decoration: none;
        }

            .nav-link-admin:hover {
                background: rgba(255,255,255,0.08);
                color: #fff;
            }

            .nav-link-admin.active {
                background: var(--mw-red);
                color: #fff;
                box-shadow: 0 4px 12px rgba(220, 53, 69, 0.35);
            }

        /* --- CUSTOMER SHARED --- */
        .navbar-mw {
            backdrop-filter: blur(10px);
            background: rgba(255, 255, 255, 0.95);
            border-bottom: 1px solid #eee;
        }

        .nav-link-custom {
            font-weight: 600;
            color: #444;
            padding: 0.5rem 1.2rem !important;
            position: relative;
        }

            .nav-link-custom::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 50%;
                width: 0;
                height: 2px;
                background: var(--mw-red);
                transition: 0.3s;
                transform: translateX(-50%);
            }

            .nav-link-custom:hover::after {
                width: 70%;
            }

            .nav-link-custom:hover {
                color: var(--mw-red);
            }

        .mw-icon-circle {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background-color: #f5f5f5;
            color: #333;
            transition: all 0.3s ease;
            text-decoration: none !important;
        }

            .mw-icon-circle:hover {
                background-color: #e0e0e0;
                color: var(--mw-red);
            }

            .mw-icon-circle i {
                font-size: 1.3rem;
            }

        #cart-badge-nav {
            position: absolute;
            top: -3px;
            right: -3px;
            background-color: var(--mw-red);
            border: 2px solid white;
            font-size: 0.7rem;
            padding: 3px 6px;
        }

        @@media (max-width: 992px) {
            .admin-sidebar

        {
            transform: translateX(-100%);
            transition: 0.3s;
        }

        .admin-main {
            margin-left: 0;
        }

        .admin-sidebar.show {
            transform: translateX(0);
        }

        }
    </style>
</head>
<body>
    @{
        var area = ViewContext.RouteData.Values["area"]?.ToString();
        var controller = ViewContext.RouteData.Values["controller"]?.ToString();
        bool isAdminArea = area == "Admin";
        var tableName = HttpContextAccessor.HttpContext?.Session.GetString("TableName");
    }

    @if (isAdminArea)
    {
        <div class="d-flex">
            <aside class="admin-sidebar shadow">
                <div class="p-4 text-center">
                    <h4 class="text-white fw-bold mb-0">MANWAH <span class="text-danger">CP</span></h4>
                    <p class="text-muted small mt-1">Management System</p>
                </div>

                <div class="mt-2">
                    <small class="text-uppercase text-secondary fw-bold px-4 mb-2 d-block" style="font-size: 10px; letter-spacing: 2px;">Main Dashboard</small>
                    <a class="nav-link-admin @(controller == "Home" ? "active" : "")" asp-area="Admin" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-grid-1x2-fill me-3"></i> Bảng điều khiển
                    </a>

                    <small class="text-uppercase text-secondary fw-bold px-4 mb-2 mt-4 d-block" style="font-size: 10px; letter-spacing: 2px;">Operations</small>
                    <a class="nav-link-admin @(controller == "Order" ? "active" : "")" asp-area="Admin" asp-controller="Order" asp-action="Index">
                        <i class="bi bi-receipt me-3"></i> Đơn hàng
                    </a>
                    <a class="nav-link-admin @(controller == "Table" ? "active" : "")" asp-area="Admin" asp-controller="Table" asp-action="Index">
                        <i class="bi bi-layers me-3"></i> Quản lý bàn
                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <small class="text-uppercase text-secondary fw-bold px-4 mb-2 mt-4 d-block" style="font-size: 10px; letter-spacing: 2px;">Catalog</small>
                        <a class="nav-link-admin @(controller == "Product" ? "active" : "")" asp-area="Admin" asp-controller="Product" asp-action="Index">
                            <i class="bi bi-egg-fried me-3"></i> Món ăn
                        </a>
                        <a class="nav-link-admin @(controller == "Category" ? "active" : "")" asp-area="Admin" asp-controller="Category" asp-action="Index">
                            <i class="bi bi-tags me-3"></i> Loại món
                        </a>

                        <small class="text-uppercase text-secondary fw-bold px-4 mb-2 mt-4 d-block" style="font-size: 10px; letter-spacing: 2px;">People</small>
                        <a class="nav-link-admin @(controller == "User" ? "active" : "")" asp-area="Admin" asp-controller="User" asp-action="Index">
                            <i class="bi bi-people me-3"></i> Khách hàng
                        </a>
                        <a class="nav-link-admin @(controller == "Staff" ? "active" : "")" asp-area="Admin" asp-controller="Staff" asp-action="Index">
                            <i class="bi bi-person-vcard me-3"></i> Nhân viên
                        </a>
                    }
                </div>
            </aside>

            <main class="admin-main w-100">
                <header class="bg-white border-bottom sticky-top px-4 py-2 d-flex align-items-center justify-content-between">
                    <div>
                        <button class="btn btn-light d-lg-none me-2" onclick="$('.admin-sidebar').toggleClass('show')">
                            <i class="bi bi-list"></i>
                        </button>
                        <span class="fw-bold text-dark">@ViewData["Title"]</span>
                    </div>

                    <div class="dropdown">
                        <div class="d-flex align-items-center gap-3 border rounded-pill p-1 ps-3" data-bs-toggle="dropdown" style="cursor: pointer;">
                            <div class="text-end d-none d-sm-block">
                                <p class="mb-0 small fw-bold">@User.Identity.Name</p>
                                <small class="text-danger" style="font-size: 10px;">@(User.IsInRole("Admin") ? "Administrator" : "Staff")</small>
                            </div>
                            <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 35px; height: 35px;">
                                <i class="bi bi-person"></i>
                            </div>
                        </div>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                            <li><a class="dropdown-item" asp-area="Customer" asp-controller="Home" asp-action="Index"><i class="bi bi-globe me-2"></i> Xem Website</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger fw-bold" asp-area="Admin" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</a></li>
                        </ul>
                    </div>
                </header>

                <div class="p-4">
                    @RenderBody()
                </div>
            </main>
        </div>
    }
    else
    {
        <nav class="navbar navbar-expand-lg navbar-mw sticky-top py-3">
            <div class="container">
                <a class="navbar-brand me-5" asp-area="Customer" asp-controller="Home" asp-action="Index">
                    <img src="~/images/Logo.png" asp-append-version="true" alt="Manwah" height="100">
                </a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#mwNav">
                    <span class="bi bi-grid-fill fs-3"></span>
                </button>

                <div class="collapse navbar-collapse" id="mwNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link nav-link-custom" asp-area="Customer" asp-controller="Menu" asp-action="Index">THỰC ĐƠN</a></li>
                        <li class="nav-item"><a class="nav-link nav-link-custom" asp-area="Customer" asp-controller="Table" asp-action="Index">SƠ ĐỒ BÀN</a></li>
                        <li class="nav-item"><a class="nav-link nav-link-custom" href="#">ƯU ĐÃI</a></li>
                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        @if (User.Identity.IsAuthenticated)
                        {
                            <div class="d-none d-md-block text-end me-2">
                                <small class="text-muted d-block" style="font-size: 10px;">Chào mừng,</small>
                                <span class="fw-bold small">@User.Identity.Name</span>
                            </div>

                            @if (!string.IsNullOrEmpty(tableName))
                            {
                                <div class="mw-icon-circle shadow-sm border border-danger border-2" title="Bàn hiện tại">
                                    <span class="fw-bold text-danger" style="font-size: 0.9rem;">@tableName</span>
                                </div>
                            }

                            <a asp-area="Customer" asp-controller="Order" asp-action="History" class="mw-icon-circle shadow-sm" title="Lịch sử đơn hàng">
                                <i class="bi bi-clock"></i>
                            </a>

                            <a asp-area="Customer" asp-controller="Cart" asp-action="Index" class="mw-icon-circle shadow-sm" title="Giỏ hàng">
                                <i class="bi bi-cart3"></i>
                                <span id="cart-badge-nav" class="badge rounded-pill bg-danger" style="display:none;">0</span>
                            </a>
                        }
                        else
                        {
                            <a class="btn btn-outline-dark border-0 fw-bold small rounded-pill px-4" asp-area="Customer" asp-controller="Account" asp-action="Login">ĐĂNG NHẬP</a>
                        }

                        <a asp-area="Customer" asp-controller="Table" asp-action="Index" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm border-0">
                            ĐẶT BÀN
                        </a>
                    </div>
                </div>
            </div>
        </nav>

        <main role="main">
            @RenderBody()
        </main>

        <footer class="bg-dark text-white pt-5 pb-3 mt-5">
            <div class="container text-center">
                <img src="~/images/Logo.png" asp-append-version="true" alt="Manwah" height="100">
                <h6 class="fw-bold ls-1">江安火锅 Manwah</h6>
                <div class="d-flex justify-content-center gap-3 my-4">
                    <a href="#" class="btn btn-outline-light btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width:35px;height:35px;"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="btn btn-outline-light btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width:35px;height:35px;"><i class="bi bi-instagram"></i></a>
                    <a href="#" class="btn btn-outline-light btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width:35px;height:35px;"><i class="bi bi-youtube"></i></a>
                </div>
                <p class="text-secondary small">&copy; 2026 Manwah Restaurant Group. Crafted with passion.</p>
            </div>
        </footer>
    }

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            updateCartBadge();
        });

        function updateCartBadge() {
            $.get('@Url.Action("GetCartCount", "Cart", new { area = "Customer" })', function(count) {
                const badge = $('#cart-badge-nav');
                if (count > 0) {
                    badge.text(count).show();
                } else {
                    badge.hide();
                }
            }).fail(function() {
                console.warn("Cart badge update failed.");
            });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>